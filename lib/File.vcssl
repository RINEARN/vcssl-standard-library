 *
 * @param pathOrName The name or path of the target directory.
 * @return The list of file names directly under the specified directory (the order depends on the environment).
 */
string[] getFileList( string pathOrName ){
  return SYSTEM_PROCESS_DRIVER_FILE_getFileList( pathOrName );
}

