 * @param count クリック数（ シングルクリックなら 1、ダブルクリックなら 2 ）
 *
 * !--- locale=En-US ---
 * Called when the mouse is clicked.
 * 
 * @param componentID The ID of the component where the event occurred.
 * @param x The X coordinate of the mouse.
 * @param y The Y coordinate of the mouse.
 * @param button The constant identifying the mouse button, either <a href="#MOUSE_RIGHT">MOUSE_RIGHT</a>, <a href="#MOUSE_LEFT">MOUSE_LEFT</a>, or <a href="#MOUSE_RIGHT">MOUSE_MIDDLE</a>.
 * @param count The click count, where 1 means a single click and 2 means a double click.
 */
void onMouseClick( int componentID, int x, int y, int button, int count ) {
}

