 */
void onMouseUp( int componentID, int x, int y, int button ) {
}

/**
 * !--- locale=Ja-JP ---
 * マウスがクリックされた際にコールされます。
 * 
 * @param componentID イベント発生元コンポーネントのID
 * @param x マウスのX座標
 * @param y マウスのX座標
