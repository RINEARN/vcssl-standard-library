 * @param locationX The X component of the origin position.
 * @param locationY The Y component of the origin position.
 * @param locationZ The Z component of the origin position.
 */
void setCameraOrigin( int worldID, float x, float y, float z ){
  setCoordinateOrigin( worldID, 0.0, 0.0, 0.0 );
  walkCoordinate( worldID, -x, -y, -z );
}

/**
