 *
 * !--- locale=En-US ---
 * Gets the inner product of vectors.
 * 
 * @param vector1 The ID of one vector used for the inner-product calculation.
 * @param vector2 The ID of the other vector used for the inner-product calculation.
 * @return The inner product.
 */
float getVectorInnerProduct( int vector1, int vector2 ){
  return SYSTEM_PROCESS_DRIVER_GRAPHICS_getVectorInnerProduct3D( vector1, vector2 );
}

/**
