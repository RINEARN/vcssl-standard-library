 * @return 外積を代入するベクトルのID
 *
 * !--- locale=En-US ---
 * Gets the cross product of vectors, stores it into a newly created vector, and returns that vector.
 * 
 * @param vector1 The ID of one vector used for the cross-product calculation.
 * @param vector2 The ID of the other vector used for the cross-product calculation.
 * @return The ID of the vector that stores the cross product.
 */
int getVectorCrossProduct( int vector1, int vector2 ){
  return SYSTEM_PROCESS_DRIVER_GRAPHICS_getVectorCrossProduct3D( vector1, vector2 );
}

/**
