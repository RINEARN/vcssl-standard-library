 *
 * !--- locale=En-US ---
 * Gets the X component of the screen projection of the vector.
 * 
 * @param vectorID The ID of the target vector.
 * @param rendererID The renderer ID.
 * @return The X coordinate of the projected vector in the drawing area (the left-bottom edge of the drawing area is 0).
 */
int projectVectorX( int vectorID, int rendererID ){
  return SYSTEM_PROCESS_DRIVER_GRAPHICS_projectVector3DX( vectorID, rendererID );
}

/**
 * !--- locale=Ja-JP ---
