 * 
 * @param vectorID The ID of the target vector.
 * @param rendererID The renderer ID.
 * @return The Y coordinate of the projected vector in the drawing area (the left-bottom edge of the drawing area is 0).
 */
int projectVectorY( int vectorID, int rendererID ){
  return SYSTEM_PROCESS_DRIVER_GRAPHICS_projectVector3DY( vectorID, rendererID );
}


/**
 * !--- locale=Ja-JP ---
 * ベクトルを座標変換し、引数に指定されたベクトルに代入します。
 * 
