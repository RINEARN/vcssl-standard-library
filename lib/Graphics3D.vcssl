 *
 * !--- locale=En-US ---
 * Sets the magnitude (absolute value) of the vector.
 * In this operation, the direction of the vector, that is, the ratio among its X, Y, and Z components, is preserved.
 * 
 * @param vectorID The ID of the target vector.
 * @param newlength The new magnitude.
 */
macro setVectorLength( int vectorID, float newlength ){
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setVector3DLength( vectorID, newlength );
}

