 * !--- locale=En-US ---
 * Sets the graphics resource of the polygon.
 * Since VCSSL 3.3.24, the newer <a href="#setPolygonImage">setPolygonImage</a> function has been supported.
 * This function is supported for compatibility.
 * 
 * @param polygonID The ID of the target polygon.
 * @param graphicsID The ID of the graphics resource.
 */
macro setPolygonGraphics( int polygonID, int graphicsID ){
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DImage( polygonID, graphicsID );
}

