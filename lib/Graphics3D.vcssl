 *
 * !--- locale=En-US ---
 * Sets the emissive coefficient of the polygon.
 * 
 * @param polygonID The ID of the target polygon.
 * @param rate The emissive coefficient.
 */
void setPolygonEmissive( int polygonID, float rate ){
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DEmission( polygonID, rate );
}

/**
