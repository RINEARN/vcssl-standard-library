 *
 * !--- locale=En-US ---
 * Sets the position or direction vector of the light.
 * 
 * @param lightID The ID of the target light.
 * @param vectorID The ID of the position or direction vector.
 */
void setLightLocation( int lightID, int vectorID ){
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DVertex( lightID, SYSTEM_PROCESS_DRIVER_GRAPHICS_getVector3DX(vectorID), SYSTEM_PROCESS_DRIVER_GRAPHICS_getVector3DY(vectorID), SYSTEM_PROCESS_DRIVER_GRAPHICS_getVector3DZ(vectorID) );
}


/**
 * !--- locale=Ja-JP ---
 * ライトの位置または方向を取得します。
 * 
 * @param lightID 対象ライトのID
 * @return 位置または方向（ [0]がX成分、[1]がY成分、[2]がZ成分 ）
 *
 * !--- locale=En-US ---
 * Gets the position or direction of the light.
 * 
 * @param lightID The ID of the target light.
 * @return The position or direction ([0]: X component, [1]: Y component, [2]: Z component).
 */
float[] getLightLocation( int lightID ){
	float[][] vertex = SYSTEM_PROCESS_DRIVER_GRAPHICS_getElement3DVertex2( lightID );
	float vector[3];
	vector[0] = vertex[0][0];
	vector[1] = vertex[0][1];
	vector[2] = vertex[0][2];
	return vector;
}

/**
 * !--- locale=Ja-JP ---
 * ライトの位置または方向を取得し、引数に指定されたベクトルに代入します。
 * 
 * @param lightID 対象ライトのID
 * @param vectorID 位置または方向を格納するベクトルのID
 *
 * !--- locale=En-US ---
 * Gets the position or direction of the light and stores it into the specified vector.
 * 
 * @param lightID The ID of the target light.
 * @param vectorID The ID of the vector that receives the position or direction.
 */
void getLightLocation( int lightID, int vectorID ){
	float[][] vertex = SYSTEM_PROCESS_DRIVER_GRAPHICS_getElement3DVertex2( lightID );
	float vector[3];
	vector[0] = vertex[0][0];
	vector[1] = vertex[0][1];
	vector[2] = vertex[0][2];
	SYSTEM_PROCESS_DRIVER_GRAPHICS_setVector3D(vectorID, vector[0], vector[1], vector[2]);
}






















































