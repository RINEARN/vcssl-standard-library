  int id = SYSTEM_PROCESS_DRIVER_GRAPHICS_createLineElement3D();
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DVertexVector( id, aVectorID, bVectorID );
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DSize( id, width );
