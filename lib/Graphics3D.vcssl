  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DFrontCulling( polygonID, frontCulling );
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DBackCulling( polygonID, backCulling );
}
