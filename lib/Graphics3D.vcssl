 */
void getModelPolygonVertex( int modelID, int polygonIndex, ... int vectorID[] ){
	SYSTEM_PROCESS_DRIVER_GRAPHICS_getModel3DElementVertexVector( modelID, polygonIndex, vectorID );
}


