 * Mounts the light onto the specified coordinate system.
 * 
 * @param lightID The ID of the target light.
 * @param rendererID The renderer ID.
 * @param coordinateID The ID of the destination coordinate system.
 */
void mountLight( int lightID, int rendererID, int coordinateID ){
  SYSTEM_PROCESS_DRIVER_GRAPHICS_addElement3D( lightID, rendererID, coordinateID );
}

