 *
 * !--- locale=En-US ---
 * Sets the ambient reflection coefficient of the polygon.
 * 
 * @param polygonID The ID of the target polygon.
 * @param rate The ambient reflection coefficient.
 */
void setPolygonAmbient( int polygonID, float rate ){
  SYSTEM_PROCESS_DRIVER_GRAPHICS_setElement3DAmbientReflection( polygonID, rate );
}

/**
 * !--- locale=Ja-JP ---
