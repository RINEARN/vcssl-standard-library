		while( value != value_stock ){
			value_stock = value;
			value = value - ( tanh(value) - arg )*( 1.0vf - arg*arg );
		}
	}

	if(minus){
		value = -value;
	}

	digit( digitStock );
	value += 0vf;
	return value;
}



















