}

/**
 * !--- locale=Ja-JP ---
 * 階乗を計算します。
 *
 * @param arg 計算対象の値。
 * @return 計算結果の値。
 *
 * !--- locale=En-US ---
 * Calculates the factorial.
 *
 * @param arg The value to be calculated.
 * @return The calculated value.
 */
varint fac( varint arg ){

	varint value = arg;

	if( arg <= 0vf ){
		value = 1v;
		return 1v;
	}

	for( varint i=arg-1v; 1v<i; i-- ){
		value = value * i;
	}
	return value;

}

/**
 * !--- locale=Ja-JP ---
 * 階乗を計算します。
 *
 * @param arg 計算対象の値。
 * @return 計算結果の値。
 *
 * !--- locale=En-US ---
 * Calculates the factorial.
 *
 * @param arg The value to be calculated.
 * @return The calculated value.
 */
varfloat fac( varfloat arg ){

	varint intArgFloor = arg;
	varint intArgCeil = arg+1v;
	varint intArg = intArgFloor;

	if( abs(intArgCeil-arg) < abs(intArgFloor-arg) ){
		intArg = intArgCeil;
	}

	varfloat value = fac( intArg );
	return value;

}





