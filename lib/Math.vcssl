varfloat rad(varfloat deg){
	int digitStock = digit();
	digit( digitStock * 1.34 );
	varfloat value = deg * pi() / 180.0vf;
	digit( digitStock );
	return value;
}































// 内部処理用
macro order( varfloat arg ){
	return SYSTEM_PROCESS_FPU_orderVF( arg );
}






