 * Because this shorter name is somewhat ambiguous in meaning and specification, use of the more explicit names
 * <a href="#FLOAT_MIN_ABS_DENORMAL">FLOAT_MIN_ABS_DENORMAL</a> or
 * <a href="#FLOAT_MIN_ABS_NORMAL">FLOAT_MIN_ABS_NORMAL</a> is generally recommended.
 */
public const float FLOAT_MIN = ___FLOAT_MIN_ABS_DENORMAL;

