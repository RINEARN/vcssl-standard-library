/**
 * !--- locale=Ja-JP ---
 * <p>
 * VCSSL Text ライブラリ は、テキスト（文字列）処理を扱う標準ライブラリです。
 * </p>
 *
 * <p>
 * このライブラリでは、文字列を扱う string 型の変数に対して、
 * 長さや部分文字列の取得、検索と置換、分割などの機能を提供します。
 * なお、検索、置換、分割では、正規表現を用いる事もできます。
 * </p>
 *
 * @author  松井文宏 ( RINEARN )
 * @license Public domain ( CC0 )
 *
 * !--- locale=En-US ---
 * <p>
 * The VCSSL Text library is a standard library for text processing.
 * </p>
 *
 * <p>
 * This library provides features such as obtaining lengths and substrings,
 * searching and replacing, and splitting for string variables.
 * Regular expressions can also be used in searching, replacing, and splitting.
 * </p>
 *
 * @author  Fumihiro Matsui ( RINEARN )
 * @license Public domain ( CC0 )
 */


import System;

/**
 * !--- locale=Ja-JP ---
 * 文字列と一致する、全ての部分を探す検索モードです。
 *
 * !--- locale=En-US ---
 * The search mode for finding all parts matching a string.
 */
public const int ALL = 101;

/**
 * !--- locale=Ja-JP ---
 * 正規表現と一致する、全ての部分を探す検索モードです。
 *
 * !--- locale=En-US ---
 * The search mode for finding all parts matching a regular expression.
 */
public const int ALL_PATTERN = 102;

/**
 * !--- locale=Ja-JP ---
 * 文字列と一致する、最初の部分を探す検索モードです。
 *
 * !--- locale=En-US ---
 * The search mode for finding the first part matching a string.
 */
public const int FIRST = 201;

/**
 * !--- locale=Ja-JP ---
 * 正規表現と一致する、最初の部分を探す検索モードです。
 *
 * !--- locale=En-US ---
 * The search mode for finding the first part matching a regular expression.
 */
public const int FIRST_PATTERN = 202;

/**
 * !--- locale=Ja-JP ---
 * 文字列と一致する、最後の部分を探す検索モードです。
 *
 * !--- locale=En-US ---
 * The search mode for finding the last part matching a string.
 */
public const int LAST = 301;

/**
 * !--- locale=Ja-JP ---
 * 正規表現と一致する、最後の部分を探す検索モードです。
 *
 * !--- locale=En-US ---
 * The search mode for finding the last part matching a regular expression.
 */
public const int LAST_PATTERN = 302;


/**
 * !--- locale=Ja-JP ---
 * 文字列の先頭が、部分文字列と一致するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether the beginning of a string matches a substring.
 */
public const int START = 10001;

/**
 * !--- locale=Ja-JP ---
 * 文字列の先頭が、正規表現と一致するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether the beginning of a string matches a regular expression.
 */
public const int START_PATTERN = 10002;

/**
 * !--- locale=Ja-JP ---
 * 文字列の終端が、部分文字列と一致するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether the end of a string matches a substring.
 */
public const int END = 10003;

/**
 * !--- locale=Ja-JP ---
 * 文字列の終端が、正規表現と一致するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether the end of a string matches a regular expression.
 */
public const int END_PATTERN = 10004;

/**
 * !--- locale=Ja-JP ---
 * 文字列のどこかに、部分文字列と一致する部分が存在するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether any part of a string matches a substring.
 */
public const int CONTAIN = 10005;

/**
 * !--- locale=Ja-JP ---
 * 文字列のどこかに、正規表現と一致する部分が存在するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether any part of a string matches a regular expression.
 */
public const int CONTAIN_PATTERN = 10006;

/**
 * !--- locale=Ja-JP ---
 * 文字列の全体が、正規表現と一致するかを判断する判定モードです。
 *
 * !--- locale=En-US ---
 * The checking mode for determining whether an entire string matches a regular expression.
 */
public const int FULL_PATTERN = 10007;


/**
 * !--- locale=Ja-JP ---
 * 前後の空白・改行を切り詰める、adjustText 関数のモードです。
 *
 * !--- locale=En-US ---
 * The mode of the adjustText function for trimming leading and trailing whitespace and line breaks.
 */
public const int TRIM = 20001;

/**
 * !--- locale=Ja-JP ---
 * 大文字のアルファベットを小文字にする、adjustText 関数のモードです。
 *
 * !--- locale=En-US ---
 * The mode of the adjustText function for converting uppercase alphabetic characters to lowercase.
 */
public const int LOWER_CASE = 20002;

/**
 * !--- locale=Ja-JP ---
 * 小文字のアルファベットを大文字にする、adjustText 関数のモードです。
 *
 * !--- locale=En-US ---
 * The mode of the adjustText function for converting lowercase alphabetic characters to uppercase.
 */
public const int UPPER_CASE = 20003;


/** エラーメッセージ、不明な検索モードが指定された場合 */
private const string ERROR_UNKNOWN_MODE = "The specified mode is not available for this function. 指定されたモードは、この関数では未対応です：";


private string toConstName(int mode) {
	if (mode == ALL) {
		return "FIRST";
	} else if (mode == ALL_PATTERN) {
		return "FIRST_PATTERN";
	} else if (mode == LAST) {
		return "LAST";
	} else if (mode == LAST_PATTERN) {
		return "LAST_PATTERN";
	} else if (mode == ALL) {
		return "ALL";
	} else if (mode == ALL_PATTERN) {
		return "ALL_PATTERN";
	} else if (mode == START) {
		return "START";
	} else if (mode == START_PATTERN) {
		return "START_PATTERN";
	} else if (mode == END) {
		return "END";
	} else if (mode == END_PATTERN) {
		return "END_PATTERN";
	} else if (mode == CONTAIN) {
		return "CONTAIN";
	} else if (mode == CONTAIN_PATTERN) {
		return "CONTAIN_PATTERN";
	} else if (mode == FULL_PATTERN) {
		return "FULL_PATTERN";
	} else if (mode == UPPER_CASE) {
		return "UPPER_CASE";
	} else if (mode == LOWER_CASE) {
		return "LOWER_CASE";
	} else if (mode == TRIM) {
		return "TRIM";
	} else {
		return mode;
	}
}




/**
 * !--- locale=Ja-JP ---
 *
 * 文字列内の、指定されたインデックスの位置にある文字を、1文字のstring型変数として返します。
 *
 * @param text 対象の文字列
 * @param index 文字の位置インデックス
 * @return 文字
 *
 * !--- locale=En-US ---
 *
 * Returns the character at the specified index in a string as a one-character string value.
 *
 * @param text The target string.
 * @param index The character index.
 * @return The character.
 */
string atText( string text, int index ){
  return SYSTEM_PROCESS_DRIVER_TEXT_getCharacter( text, index );
}


/**
 * !--- locale=Ja-JP ---
 *
 * 文字列の先頭、末尾、または全体が、指定された文字列か正規表現に一致するかを判定します。
 *
 * @param text 対象のテキスト
 * @param query 一致を判定する部分文字列
 * @param mode 判定モード（ <a href="#START">START</a>, <a href="#END">END</a>, <a href="#CONTAIN">CONTAIN</a>, <a href="#START_PATTERN">START_PATTERN</a>, <a href="#END_PATTERN">END_PATTERN</a>, <a href="#CONTAIN_PATTERN">CONTAIN_PATTERN</a>, <a href="#FULL_PATTERN">FULL_PATTERN</a> ）
 * @return 判定結果（ 一致すれば true ）
 *
 * !--- locale=En-US ---
 *
 * Determines whether the beginning, end, or whole of a string matches the specified string or regular expression.
 *
 * @param text The target text.
 * @param query The substring used for matching.
 * @param mode The checking mode ( <a href="#START">START</a>, <a href="#END">END</a>, <a href="#CONTAIN">CONTAIN</a>, <a href="#START_PATTERN">START_PATTERN</a>, <a href="#END_PATTERN">END_PATTERN</a>, <a href="#CONTAIN_PATTERN">CONTAIN_PATTERN</a>, <a href="#FULL_PATTERN">FULL_PATTERN</a> ).
 * @return The result of the check (true if matched).
 */
public bool checkText( string text, string query, int mode ) {
	
	if (mode == START) {
		
		return SYSTEM_PROCESS_DRIVER_TEXT_startsWith( text, query );
		
	} else if (mode == END) {
		
		return SYSTEM_PROCESS_DRIVER_TEXT_endsWith( text, query );
		
	} else if (mode == CONTAIN) {
		
		int index[] = findText(text, query, FIRST);
		
		if (length(index, 0) == 0) {
			return false;
			
		} else if (0 <= index[0]) {
			return true;
			
		} else {
			return false;
		}
		
	} else if (mode == START_PATTERN) {
		
		int index[] = findText(text, query, FIRST_PATTERN);
		
		if (length(index, 0) == 0) {
			return false;
			
		} else if (index[0] == 0) {
			return true;
			
		} else {
			return false;
		}
		
	} else if (mode == END_PATTERN) {
		
		int textLength = countText(text);
		int index[] = findText(text, query, LAST_PATTERN);
		string ext[] = extractText(text, query, LAST_PATTERN);
		
		if (length(index, 0) == 0) {
			return false;
			
		} else if (index[0] == textLength - countText(ext[0])) {
			return true;
			
		} else {
			return false;
		}
		
	} else if (mode == CONTAIN_PATTERN) {
		
		int index[] = findText(text, query, FIRST_PATTERN);
		
		if (length(index, 0) == 0) {
			return false;
			
		} else if (0 <= index[0]) {
			return true;
			
		} else {
			return false;
		}
		
	} else if (mode == FULL_PATTERN) {
		
		return SYSTEM_PROCESS_DRIVER_TEXT_totalMatch( text, query );
		
	} else {
		System.error(ERROR_UNKNOWN_MODE + toConstName(mode));
		return false;
	}
}




/**
 * !--- locale=Ja-JP ---
 *
 * テキストを、指定されたモードで調整します。
 * <br />
 * モードに応じて、テキストの前後に含まれている空白・改行部分を取り除いたり、アルファベットを大文字/小文字に揃えたりできます。
 *
 * @param text 対象のテキスト
 * @param mode 調整モード（ <a href="#TRIM">TRIM</a>, <a href="#LOWER_CASE">LOWER_CASE</a>, <a href="#UPPER_CASE">UPPER_CASE</a>）
 * @return 調整済みのテキスト
 *
 * !--- locale=En-US ---
 *
 * Adjusts text in the specified mode.
 * <br />
 * Depending on the mode, leading and trailing whitespace and line breaks can be removed, or alphabetic characters can be unified to uppercase or lowercase.
 *
 * @param text The target text.
 * @param mode The adjustment mode ( <a href="#TRIM">TRIM</a>, <a href="#LOWER_CASE">LOWER_CASE</a>, <a href="#UPPER_CASE">UPPER_CASE</a> ).
 * @return The adjusted text.
 */
public string adjustText( string text, int mode ){
  if (mode == LOWER_CASE || mode == UPPER_CASE || mode == TRIM) {
    return SYSTEM_PROCESS_DRIVER_TEXT_adjust( text, mode );

  } else {
    System.error(ERROR_UNKNOWN_MODE + toConstName(mode));
  }
}


/**
 * !--- locale=Ja-JP ---
 *
 * テキストから、指定された範囲を抜き出したものを返します。
 * <br />
 * 抜き出す範囲は、テキストの各文字に、先頭を 0 としてインデックスを割りふると、cropBegin 番目から cropEnd - 1 番目までの文字列となります。
 * また、文字と文字の「 隙間（すきま） 」にインデックスを割りふると、抜き出す範囲はちょうど cropBegin 番目から cropEnd 番目までの隙間に挟まれた範囲となります。
 *
 * @param text 対象のテキスト
 * @param cropBegin 抜き出す範囲の開始位置
 * @param cropEnd 抜き出す範囲の終了位置
 * @return 抜き出された範囲のテキスト
 *
 * !--- locale=En-US ---
 *
 * Returns the specified range extracted from a text.
 * <br />
 * If indices are assigned to the characters of the text starting from 0, the extracted range is the substring from cropBegin to cropEnd - 1.
 * Also, if indices are assigned to the gaps between characters, the extracted range is exactly the part between the gap at cropBegin and the gap at cropEnd.
 *
 * @param text The target text.
 * @param cropBegin The starting position of the range to be extracted.
 * @param cropEnd The ending position of the range to be extracted.
 * @return The extracted text.
 */
public string cropText( string text, int cropBegin, int cropEnd ){
  return SYSTEM_PROCESS_DRIVER_TEXT_getSubtext( text, cropBegin, cropEnd );
}



/**
 * !--- locale=Ja-JP ---
 *
 * テキストの文字数をカウントして返します。
 *
 * @param text 対象のテキスト
 * @return テキストの文字数
 *
 * !--- locale=En-US ---
 *
 * Counts and returns the number of characters in a text.
 *
 * @param text The target text.
 * @return The number of characters in the text.
 */
public int countText( string text ){
  return SYSTEM_PROCESS_DRIVER_TEXT_countTextLength( text );
}

/**
 * !--- locale=Ja-JP ---
 *
 * テキストから、部分文字列（ または正規表現 ）に一致する箇所を検索し、その個数をカウントして返します。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索結果の個数
 *
 * !--- locale=En-US ---
 *
 * Searches a text for parts matching a substring or regular expression, and returns the number of matches.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return The number of matches.
 */
public int countText( string text, string query, int mode ){
	int indices[] = findText(text, query, mode);
	int n = length(indices, 0);
	return n;
}

/**
 * !--- locale=Ja-JP ---
 *
 * テキストの指定位置以降から、部分文字列（ または正規表現 ）に一致する箇所を検索し、その個数をカウントして返します。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param searchBegin 検索開始位置の文字インデックス
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索結果の個数
 *
 * !--- locale=En-US ---
 *
 * Searches a text for parts matching a substring or regular expression from the specified position onward, and returns the number of matches.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param searchBegin The character index of the search starting position.
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return The number of matches.
 */
public int countText( string text, string query, int searchBegin, int mode ){
	int indices[] = findText(text, query, searchBegin, mode);
	int n = length(indices, 0);
	return n;
}

/**
 * !--- locale=Ja-JP ---
 *
 * テキストの指定範囲内から、部分文字列（ または正規表現 ）に一致する箇所を検索し、その個数をカウントして返します。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param searchBegin 検索開始位置の文字インデックス
 * @param searchEnd 検索終了位置の文字インデックス + 1 （ <a href="#cropText">cropText</a> 参照 ）
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索結果の個数
 *
 * !--- locale=En-US ---
 *
 * Searches within the specified range of a text for parts matching a substring or regular expression, and returns the number of matches.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param searchBegin The character index of the search starting position.
 * @param searchEnd The character index of the search ending position plus 1 (see <a href="#cropText">cropText</a>).
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return The number of matches.
 */
public int countText( string text, string query, int searchBegin, int searchEnd, int mode ){
	int indices[] = findText(text, query, searchBegin, searchEnd, mode);
	int n = length(indices, 0);
	return n;
}



/**
 * !--- locale=Ja-JP ---
 *
 * テキストから、部分文字列（ または正規表現 ）に一致する箇所を検索し、一致箇所の文字インデックスを配列にまとめて返します。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索一致箇所の文字インデックスを格納する配列
 *
 * !--- locale=En-US ---
 *
 * Searches a text for parts matching a substring or regular expression, and returns an array containing the character indices of the matched parts.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return An array storing the character indices of the matched parts.
 */
public int[] findText( string text, string query, int mode ) {
	
	if (mode == FIRST) {
		
		int index = SYSTEM_PROCESS_DRIVER_TEXT_getWordIndex(text, query);
		if (0 <= index) {
			int result[] = { index };
			return result;
		} else {
			int result[0];
			return result;
		}
		
	} else if (mode == FIRST_PATTERN) {
		
		int index = SYSTEM_PROCESS_DRIVER_TEXT_getPatternWordIndex(text, query);
		if (0 <= index) {
			int result[] = { index };
			return result;
		} else {
			int result[0];
			return result;
		}
		
	} else if (mode == LAST) {
		
		int index = SYSTEM_PROCESS_DRIVER_TEXT_getLastWordIndex(text, query);
		if (0 <= index) {
			int result[] = { index };
			return result;
		} else {
			int result[0];
			return result;
		}
		
	} else if (mode == LAST_PATTERN) {
		
		int index = SYSTEM_PROCESS_DRIVER_TEXT_getPatternLastWordIndex(text, query);
		if (0 <= index) {
			int result[] = { index };
			return result;
		} else {
			int result[0];
			return result;
		}
		
	} else if (mode == ALL) {
		
		int textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getWordIndex(text, query);
		int arrayIndex = 0;
		int arraySize = 0;
		int result[arraySize];
		
		while (0 <= textIndex) {
			arraySize++;
			alloc[arraySize] result;
			result[ arrayIndex ] = textIndex;
			textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getWordIndex(text, query, textIndex+1);
			arrayIndex++;
		}
		return result;
		
	} else if (mode == ALL_PATTERN) {
		
		int textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getPatternWordIndex(text, query);
		int textLength = SYSTEM_PROCESS_DRIVER_TEXT_countTextLength(text);
		int arrayIndex = 0;
		int arraySize = 0;
		int result[arraySize];
		
		while (0 <= textIndex && textIndex < textLength) {
			arraySize++;
			alloc[arraySize] result;
			result[ arrayIndex ] = textIndex;
			textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getPatternWordIndex(text, query, textIndex+1);
			arrayIndex++;
		}
		return result;
		
	} else {
		System.error(ERROR_UNKNOWN_MODE + toConstName(mode));
		int result[0];
		return result;
	}
}

/**
 * !--- locale=Ja-JP ---
 *
 * テキスト指定位置以降から、部分文字列（ または正規表現 ）に一致する箇所を検索し、一致箇所の文字インデックスを配列にまとめて返します。
 * 検索で一致する箇所が無かった場合、戻り値は要素数 0 の配列となります。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param searchBegin 検索開始位置の文字インデックス
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索一致箇所の文字インデックスを格納する配列
 *
 * !--- locale=En-US ---
 *
 * Searches from the specified position onward in a text for parts matching a substring or regular expression, and returns an array containing the character indices of the matched parts.
 * If no match is found, the return value is an array with zero elements.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param searchBegin The character index of the search starting position.
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return An array storing the character indices of the matched parts.
 */
public int[] findText( string text, string query, int searchBegin, int mode ) {
	int textLength = SYSTEM_PROCESS_DRIVER_TEXT_countTextLength(text);
	string croppedText = SYSTEM_PROCESS_DRIVER_TEXT_getSubtext(text, searchBegin, textLength);
	int result[] = findText(croppedText, query, mode);
	result += searchBegin;
	return result;
}

/**
 * !--- locale=Ja-JP ---
 *
 * テキスト指定範囲内から、部分文字列（ または正規表現 ）に一致する箇所を検索し、一致箇所の文字インデックスを配列にまとめて返します。
 * 検索で一致する箇所が無かった場合、戻り値は要素数 0 の配列となります。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param searchBegin 検索開始位置の文字インデックス
 * @param searchEnd 検索終了位置の文字インデックス + 1 （ <a href="#cropText">cropText</a> 参照 ）
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索一致箇所の文字インデックスを格納する配列
 *
 * !--- locale=En-US ---
 *
 * Searches within the specified range of a text for parts matching a substring or regular expression, and returns an array containing the character indices of the matched parts.
 * If no match is found, the return value is an array with zero elements.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param searchBegin The character index of the search starting position.
 * @param searchEnd The character index of the search ending position plus 1 (see <a href="#cropText">cropText</a>).
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return An array storing the character indices of the matched parts.
 */
public int[] findText( string text, string query, int searchBegin, int searchEnd, int mode ) {
	string croppedText = SYSTEM_PROCESS_DRIVER_TEXT_getSubtext(text, searchBegin, searchEnd);
	int result[] = findText(croppedText, query, mode);
	result += searchBegin;
	return result;
}




/**
 * !--- locale=Ja-JP ---
 *
 * テキストから、部分文字列（ または正規表現 ）に一致する箇所を検索し、一致箇所を抜き出した文字列を配列にまとめて返します。
 * 検索で一致する箇所が無かった場合、戻り値は要素数 0 の配列となります。
 *
 * @param text 対象のテキスト
 * @param query 検索する部分文字列
 * @param mode 検索モード（ <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ）
 * @return 検索一致箇所を抜き出した文字列を格納する配列
 *
 * !--- locale=En-US ---
 *
 * Searches a text for parts matching a substring or regular expression, and returns an array containing the extracted matched strings.
 * If no match is found, the return value is an array with zero elements.
 *
 * @param text The target text.
 * @param query The substring to search for.
 * @param mode The search mode ( <a href="#ALL">ALL</a>, <a href="#FIRST">FIRST</a>, <a href="#LAST">LAST</a>, <a href="#ALL_PATTERN">ALL_PATTERN</a>, <a href="#FIRST_PATTERN">FIRST_PATTERN</a>, <a href="#LAST_PATTERN">LAST_PATTERN</a> ).
 * @return An array storing the extracted matched strings.
 */
public string[] extractText( string text, string query, int mode ) {

	if (mode == FIRST) {
		
		int index = SYSTEM_PROCESS_DRIVER_TEXT_getWordIndex(text, query);
		if (0 <= index) {
			string result[] = { query };
			return result;
		} else {
			string result[0];
			return result;
		}
		
	} else if (mode == LAST) {
		
		int index = SYSTEM_PROCESS_DRIVER_TEXT_getLastWordIndex(text, query);
		if (0 <= index) {
			string result[] = { query };
			return result;
		} else {
			string result[0];
			return result;
		}
		
	} else if (mode == FIRST_PATTERN) {
		
		string s = SYSTEM_PROCESS_DRIVER_TEXT_firstMatch(text, query);
		if (s != NULL) {
			string result[] = { s };
			return result;
		} else {
			string result[0];
			return result;
		}
		
	} else if (mode == LAST_PATTERN) {
		
		string s = SYSTEM_PROCESS_DRIVER_TEXT_lastMatch(text, query);
		if (s != NULL) {
			string result[] = { s };
			return result;
		} else {
			string result[0];
			return result;
		}
		
	} else if (mode == ALL) {
		
		int textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getWordIndex(text, query);
		int arrayIndex = 0;
		int arraySize = 0;
		string result[arraySize];
		
		while (0 <= textIndex) {
			arraySize++;
			alloc[arraySize] result;
			result[ arrayIndex ] = query;
			textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getWordIndex(text, query, textIndex+1);
			arrayIndex++;
		}
		return result;
		
	} else if (mode == ALL_PATTERN) {
		
		int textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getPatternWordIndex(text, query);
		int textLength = SYSTEM_PROCESS_DRIVER_TEXT_countTextLength(text);
		string textWord = SYSTEM_PROCESS_DRIVER_TEXT_firstMatch(text, query);
		int arrayIndex = 0;
		int arraySize = 0;
		string result[arraySize];
		
		while (0 <= textIndex && textIndex < textLength) {
			arraySize++;
			alloc[arraySize] result;
			result[ arrayIndex ] = textWord;
			textWord = SYSTEM_PROCESS_DRIVER_TEXT_firstMatch(text, query, textIndex+1);
			textIndex = SYSTEM_PROCESS_DRIVER_TEXT_getPatternWordIndex(text, query, textIndex+1);
			arrayIndex++;
		}
		return result;
		
	} else {
		System.error(ERROR_UNKNOWN_MODE + ": " + toConstName(mode));
		int result[0];
		return result;
	}
}

/**
 * !--- locale=Ja-JP ---
 *
 * テキストの指定位置以降から、部分文字列（ または正規表現 ）に一致する箇所を検索し、一致箇所を抜き出した文字列を配列にまとめて返します。
