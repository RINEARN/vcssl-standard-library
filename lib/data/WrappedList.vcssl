/**
 * !--- locale=Ja-JP ---
 * <p>
 * このライブラリ data.WrappedList は、
 * リスト型のデータ構造を提供します。	
 * </p>
 *
 * <p>
 * このモジュールでは、リストのデータを保持する
 * ジェネリック構造体 <a href="#WrappedList">WrappedList</a> と、
 * それに対してデータを出し入れするジェネリック関数 
 * <a href="#add">add</a>, <a href="#remove">remove</a> 
 * などが提供されます。 
 * </p>
 *
 * <p>
 * なお、この data.WrappedList では、
 * 要素を <a href="DataWrapper.html">DataWrapper</a> 構造体で
 * ラッピングして保持する実装になっています。
 * <br />
 * そのため WrappedListでは、 
 * data.<a href="List.html">List</a> とは異なり、
 * 配列を要素として扱う事ができます。
 * </p>
 *
 * <p>
 * 反面、要素の出し入れの際に DataWrapper 構造体への
 * ラッピング処理を伴うため、そのオーバーヘッドの分だけ、
 * List よりも処理が重くなります。
 * <br />
 * 従って、要素が配列でない場合には、
 * WrappedList よりも List の使用が推奨されます。
 * </p>
 *
 * @author  松井文宏 ( RINEARN )
 * @license Public domain ( CC0 )
 *
 * !--- locale=En-US ---
 * <p>
 * The data.WrappedList library provides a list-type data structure.
 * </p>
 *
 * <p>
 * This module provides the generic struct <a href="#WrappedList">WrappedList</a>,
 * which stores list data,
 * and generic functions such as <a href="#add">add</a> and <a href="#remove">remove</a>
 * for adding and removing data from it.
 * </p>
 *
 * <p>
 * In data.WrappedList, elements are implemented as values wrapped and stored
 * in the <a href="DataWrapper.html">DataWrapper</a> struct.
 * <br />
 * Therefore, unlike data.<a href="List.html">List</a>,
 * WrappedList can handle arrays as elements.
 * </p>
 *
 * <p>
 * On the other hand, because adding and removing elements involves wrapping them
 * into the DataWrapper struct, processing becomes heavier than in List by that overhead.
 * <br />
 * Therefore, if the elements are not arrays,
 * using List is recommended rather than WrappedList.
 * </p>
 *
 * @author  Fumihiro Matsui ( RINEARN )
 * @license Public domain ( CC0 )
 */


import data.DataWrapper;


/**
 * !--- locale=Ja-JP ---
 * リスト構造体です。リストのデータを保持します。
 *
 * !--- locale=En-US ---
 * The list struct. It stores list data.
 */
public struct WrappedList<Type>{
	protected int size = 0;
	protected DataWrapper<Type> data[1];
}


/**
 * !--- locale=Ja-JP ---
 *
 * 要素を全て削除します。
 *
 * @param list 対象のリスト構造体
 *
 * !--- locale=En-US ---
 *
 * Removes all elements.
 *
 * @param list The target list struct.
 */
public void clear<Type>( WrappedList<Type> &list ){
	alloc[0] list.data;
	alloc[1] list.data;
	list.size = 0;
}


/**
 * !--- locale=Ja-JP ---
 *
 * 使用中のサイズを返します。
 *
 * @param list 対象のリスト構造体
 *
 * !--- locale=En-US ---
 *
 * Returns the size currently in use.
 *
 * @param list The target list struct.
 */
public int size<Type>( WrappedList<Type> &list ){
	return list.size;
}


/**
 * !--- locale=Ja-JP ---
 *
 * リストの末尾に要素を追加します。
 *
 * @param list 対象のリスト構造体
 * @param value 追加する要素
 *
 * !--- locale=En-US ---
 *
 * Adds an element to the end of the list.
 *
 * @param list The target list struct.
 * @param value The element to be added.
 */
public void add<Type>( WrappedList<Type> &list, Type value ){
	setProperLength<Type>(list);
	list.data[ list.size++ ] = wrap<Type>(value);
}


/**
 * !--- locale=Ja-JP ---
 *
 * 特定インデックスの要素を取得します。
 *
 * @param list 対象のリスト構造体
 * @param index 取得したい要素のインデックス
 * @return 指定されたインデックスの要素
 *
 * !--- locale=En-US ---
 *
 * Obtains the element at the specified index.
 *
 * @param list The target list struct.
 * @param index The index of the element to be obtained.
 * @return The element at the specified index.
 */
public Type get<Type>( WrappedList<Type> &list, int index ){
	if(list.size <= index){
		error("WrappedList index out of bounds. WrappedListのインデックスが領域外を指定しました。");
		exit();
	}
	return unwrap<Type>(list.data[ index ]);
}


/**
 * !--- locale=Ja-JP ---
 *
 * 特定インデックスの要素を代入します。
 * そのインデックスの位置にあった要素は上書きされます。
 *
 * @param list 対象のリスト構造体
 * @param index 代入したい要素のインデックス
 * @param element 代入する要素
 *
 * !--- locale=En-US ---
 *
 * Assigns an element to the specified index.
 * The element that was at that index is overwritten.
 *
 * @param list The target list struct.
 * @param index The index of the element to be assigned.
 * @param element The element to be assigned.
 */
public void set<Type>( WrappedList<Type> &list, int index, Type element ){
	if(list.size <= index){
		error("WrappedList index out of bounds. WrappedListのインデックスが領域外を指定しました。");
		exit();
	}
	list.data[ index ] = wrap<Type>(element);
}


/**
 * !--- locale=Ja-JP ---
 *
 * 特定インデックスに要素を挿入します。
 * そのインデックスの位置にあった要素は、
 * 次のインデックスの位置に移動します。
 * また、それ以降の全ての要素も、
 * インデックスが後方に 1 ずつ移動します。
 *
 * @param list 対象のリスト構造体
 * @param index 挿入したい要素のインデックス
 * @param element 挿入する要素
 *
 * !--- locale=En-US ---
 *
 * Inserts an element at the specified index.
 * The element that was at that index moves to the next index.
 * All elements after that also shift one position backward.
 *
 * @param list The target list struct.
 * @param index The index at which the element is to be inserted.
 * @param element The element to be inserted.
 */
public Type insert<Type>( WrappedList<Type> &list, int index, Type value ){
	if(list.size <= index){
		error("WrappedList index out of bounds. WrappedListのインデックスが領域外を指定しました。");
		exit();
	}
	int n = list.size;
	list.size++;
	setProperLength<Type>(list);
	for(int i=n-1; index<=i; i--){
		list.data[ i+1 ] = list.data[ i ];
	}
	list.data[ index ] = wrap<Type>(value);
}


/**
 * !--- locale=Ja-JP ---
 *
 * リストが指定された要素を含んでいるか判定します。
 *
 * @param list 対象のリスト構造体
 * @param element 含まれるか判定したい要素
 *
 * !--- locale=En-US ---
 *
 * Determines whether the list contains the specified element.
 *
 * @param list The target list struct.
 * @param element The element whose presence is to be checked.
 */
public bool contains<Type>( WrappedList<Type> &list, Type element ){
	int n = list.size;
	DataWrapper<Type> wrappedElement = wrap<Type>(element);
	for(int i=0; i<n; i++){
		if(list.data[i] == wrappedElement){
			return true;
		}
	}
	return false;
}


/**
 * !--- locale=Ja-JP ---
 *
 * 特定インデックスの要素を削除します。
 *
 * @param list 対象のリスト構造体
 * @param index 削除したい要素のインデックス
 *
 * !--- locale=En-US ---
 *
 * Removes the element at the specified index.
 *
 * @param list The target list struct.
 * @param index The index of the element to be removed.
 */
public Type removeAt<Type>( WrappedList<Type> &list, int index ){
	if(list.size <= index){
		error("WrappedList index out of bounds. WrappedListのインデックスが領域外を指定しました。");
		exit();
	}
	int n = list.size;
	for(int i=index; i<n-1; i++){
		list.data[ i ] = list.data[ i+1 ];
	}
	list.size--;
	setProperLength<Type>(list);
}


/**
 * !--- locale=Ja-JP ---
 *
 * 指定された要素を削除します。
 * 複数存在する場合は、最初のものだけが削除されます。
 *
 * @param list 対象のリスト構造体
 * @param element 削除したい要素
 *
 * !--- locale=En-US ---
 *
 * Removes the specified element.
 * If multiple such elements exist, only the first one is removed.
 *
 * @param list The target list struct.
 * @param element The element to be removed.
 */
public void remove<Type>( WrappedList<Type> &list, Type element ){
	int index = indexOf<Type>(list, element);
	if(0 <= index){
		removeAt<Type>(list, index);
	}
}


/**
 * !--- locale=Ja-JP ---
 *
 * 指定された要素を全て削除します。
 *
 * @param list 対象のリスト構造体
 * @param element 削除したい要素
 *
 * !--- locale=En-US ---
 *
 * Removes all specified elements.
 *
 * @param list The target list struct.
 * @param element The element to be removed.
 */
public void removeAll<Type>( WrappedList<Type> &list, Type element ){
	int index = indexOf<Type>(list, element);
	while( 0 <= index ){
		removeAt<Type>(list, index);
		index = indexOf<Type>(list, element);
	}
}


/**
 * !--- locale=Ja-JP ---
 *
 * 指定された要素を、
 * 先頭から後方検索し、
 * 存在すればそのインデックスを、
 * 存在しなければ-1を返します。
 *
 * @param list 対象のリスト構造体
 * @param element 検索したい要素
 *
 * !--- locale=En-US ---
 *
 * Searches for the specified element from the beginning toward the end.
 * If it exists, its index is returned.
 * If it does not exist, -1 is returned.
 *
 * @param list The target list struct.
 * @param element The element to be searched for.
 */
public int indexOf<Type>( WrappedList<Type> &list, Type element ){
	int n = list.size;
	DataWrapper<Type> wrappedElement = wrap<Type>(element);
	for(int i=0; i<n; i++){
		if(list.data[i] == wrappedElement){
			return i;
		}
	}
	return -1;
}


/**
 * !--- locale=Ja-JP ---
 *
 * 指定された要素を、
 * 指定インデックスの位置から後方検索し、
 * 存在すればそのインデックスを、
 * 存在しなければ-1を返します。
 *
 * @param list 対象のリスト構造体
 * @param element 削除したい要素
 * @param from 検索開始インデックス
 *
 * !--- locale=En-US ---
 *
 * Searches for the specified element from the specified index toward the end.
 * If it exists, its index is returned.
 * If it does not exist, -1 is returned.
 *
 * @param list The target list struct.
 * @param element The element to be searched for.
 * @param from The search starting index.
 */
public int indexOf<Type>( WrappedList<Type> &list, Type element, int from ){
	int n = list.size;
	DataWrapper<Type> wrappedElement = wrap<Type>(element);
	if(n <= from){
		error("WrappedList index out of bounds. WrappedListの検索開始インデックスが領域外を指定しました。");
	}
	for(int i=from; i<n; i++){
		if( list.data[i] == wrappedElement ){
			return i;
		}
	}
	return -1;
}


/**
 * !--- locale=Ja-JP ---
 *
 * 指定された要素を、
 * 末尾から前方検索し、
 * 存在すればそのインデックスを、
 * 存在しなければ-1を返します。
 *
 * @param list 対象のリスト構造体
 * @param element 削除したい要素
 *
 * !--- locale=En-US ---
 *
 * Searches for the specified element from the end toward the beginning.
 * If it exists, its index is returned.
 * If it does not exist, -1 is returned.
 *
 * @param list The target list struct.
 * @param element The element to be searched for.
 */
public int lastIndexOf<Type>( WrappedList<Type> &list, Type element ){
	int n = list.size;
	DataWrapper<Type> wrappedElement = wrap<Type>(element);
	for(int i=n-1; 0<=i; i--){
		if(list.data[i] == wrappedElement ){
			return i;
		}
	}
	return -1;
}


/**
 * !--- locale=Ja-JP ---
 *
 * 指定された要素を、
 * 指定インデックスの位置から後方検索し、
 * 存在すればそのインデックスを、
 * 存在しなければ-1を返します。
 *
 * @param list 対象のリスト構造体
 * @param element 削除したい要素
 * @param from 検索開始インデックス
 *
 * !--- locale=En-US ---
 *
 * Searches for the specified element backward starting from the specified index.
 * If it exists, its index is returned.
 * If it does not exist, -1 is returned.
 *
 * @param list The target list struct.
 * @param element The element to be searched for.
 * @param from The search starting index.
 */
public int lastIndexOf<Type>( WrappedList<Type> &list, Type element, int from ){
	int n = list.size;
	if(from <= 0){
		error("WrappedList index out of bounds. WrappedListの検索開始インデックスが領域外を指定しました。");
	}
	DataWrapper<Type> wrappedElement = wrap<Type>(element);
	for(int i=from; 0<=i; i--){
		if(list.data[i] == wrappedElement ){
			return i;
		}
	}
	return -1;
}


/**
 * !--- locale=Ja-JP ---
 *
 * リストが保持する全要素の順序を反転させます。
 *
 * @param list 対象のリスト構造体
 *
 * !--- locale=En-US ---
 *
 * Reverses the order of all elements held by the list.
 *
 * @param list The target list struct.
 */
public void reverse<Type>( WrappedList<Type> &list ){
	int n = list.size;
	DataWrapper<Type> rev[n];
	for(int i=0; i<n; i++){
		rev[i] = list.data[n-1-i];
	}
	list.data = rev;
}


/**
 * !--- locale=Ja-JP ---
 *
 * リストが保持する全要素を、DataWrapper配列に格納して返します。
 *
 * @param list 対象のリスト構造体
 * @return リストの全要素をまとめたDataWrapper配列
 *
 * !--- locale=En-US ---
 *
 * Stores all elements held by the list into a DataWrapper array and returns it.
 *
 * @param list The target list struct.
 * @return A DataWrapper array containing all elements of the list.
 */
public DataWrapper<Type>[] toDataWrapperArray<Type>( WrappedList<Type> &list ){
	DataWrapper<Type> array[] = list.data;
	alloc[ list.size ] array;
	return array;
}


/**
 * !--- locale=Ja-JP ---
 *
 * 使用中のサイズに適切な配列バッファ長を設定します。
 *
 * @param list 対象のリスト構造体
 *
 * !--- locale=En-US ---
 *
 * Sets an appropriate array buffer length according to the size currently in use.
 *
 * @param list The target list struct.
 */
private void setProperLength<Type>( WrappedList<Type> &list ){
	int zero = 0;
	int length = length( list.data, zero );
	int properLength = getProperLength(length, list.size);
	if(properLength != length){
		alloc[ properLength ] list.data;
	}
}


/**
 * !--- locale=Ja-JP ---
 *
 * 使用中の要素数に最適なリストバッファ長を返します。
 *
 * @param length 現在のリストバッファ長
 * @param size 現在使用中の要素数
 *
 * !--- locale=En-US ---
 *
 * Returns the optimal list buffer length for the current number of elements in use.
 *
 * @param length The current list buffer length.
 * @param size The current number of elements in use.
 */
private int getProperLength(int length, int size){
	if( length == 0 ){
		return 1;
	}else if( length <= size ){
		while( length <= size ){
			length *= 2;
		}
		return length;
	}else if( size < length/2 ){
		while( size < length/2 ){
			length /= 2;
		}
		return length;
	}else{
		return length;
	}
}

