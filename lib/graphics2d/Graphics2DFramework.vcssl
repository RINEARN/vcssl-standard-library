 *
 * @param state メインループの継続状態
 *
 * !--- locale=En-US ---
 * Sets whether the main loop continues. If it is set to false, the animation main loop exits and the program ends.
 *
 * @param state Whether the main loop continues.
 */
public void setMainLoopState(bool state){
	mainLoopState = state;
}

/**
 * !--- locale=Ja-JP ---
