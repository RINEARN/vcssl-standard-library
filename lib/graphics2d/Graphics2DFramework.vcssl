coding UTF-8;

# PRAGMA COMPILE    REFERRAL
# PRAGMA RESERVE    ALL
# PRAGMA END

import GUI;
import Graphics;
import Graphics2D;
import Time;


/**
 * !--- locale=Ja-JP ---
 * <p>
 * このライブラリ graphics2d.Graphics2DFramework は、
 * 2DCG（ 2次元グラフィックス ）を手軽に扱うための軽量フレームワークです。
 * </p>
 *
 * <p>
 * VCSSLの標準ライブラリ「 Graphics2D 」や「 GUI 」だけを用いて、ゼロから2DCGプログラムを記述する場合、
 * <br />
 * ウィンドウ・レンダラー（描画エンジン）の生成や、アニメーションループ、
 * 基本的なイベントハンドラなど、いくつかの定型的な処理を、毎回記述しなければいけません。
 * <br />
 * そこで、この Graphics2DFramework では、上述のような定型処理を、雛形のようにあらかじめ用意する事によって、手軽な2DCG利用をサポートします。
 * </p>
 *
 * <p>・必要な処理の記述</p>
 *
 * <p>
 * Graphics2DFramework は、構造的には、単体で既に完成した2DCGプログラムです。実際、単体で実行する事が可能です。
 * <br />
 * ただし、単体では何の描画内容も無いため、ただ白い画面が表示されるだけです。
 * </p>
 *
 * <p>
 * そこで実際には、自作モジュールから Graphics2DFramework を import し、3Dモデルの配置や移動など、必要な処理を記述します。
 * <br />
 * そういった処理は、いくつかの決まった名前の関数を定義し、そこに記述します。つまり、GUIなどのイベントハンドラと同じ仕組みです。
 * <br />
 * するとそれらのイベントハンドラ関数を、Graphics3DFramework が適切なタイミングで自動実行します。
 * </p>
 *
 * <p>
 * Graphics2DFramework が自動実行するイベントハンドラ関数は、下記のものがあります。定義は必須では無いので、必要な関数だけを定義し、記述して下さい。
 * <ul>
 *   <li>void onStart( int renderer ) - 起動時に一度だけ実行されます。スプライトの生成・配置などの初期化処理は、ここに記述します。旧称 initialize も使用可能です。</li>
 *   <li>void onExit( int renderer ) - 終了時に一度だけ実行されます。終了時に行いたい処理があれば、ここに記述します。旧称 finalize も使用可能です。</li>
 *   <li>void onPaint( int renderer ) - 画面更新タイミング（毎秒数十回）で毎回実行されます。アニメーションの2DCG描き込み（直接描画）を行いたい場合などは、ここに記述します。旧称 paint も使用可能です。</li>
 *   <li>void onUpdate( int renderer ) - 画面更新タイミング（毎秒数十回）の間で毎回実行されます。スプライトの移動などを行いたい場合などは、ここに記述します。旧称 update も使用可能です。</li>
 *   <li>void onResize( int renderer ) - ウィンドウサイズが変更された場合に実行されます。画面に配置したGUI部品のレイアウト調整などを行いたい場合は、ここに記述します。旧称 resize も使用可能です。</li>
 * </ul>
 * 上記関数のいずれも、引数 renderer には、2DCGレンダラーのID が渡されます。これは描画やスプライトの登録などに使用します。
 * </p>
 *
 * <p>・ウィンドウのカスタマイズ</p>
 *
 * <p>
 * Graphics2DFramework では、ウィンドウ内に余白領域を設定し、そこにボタンやテキストフィールドなどのGUI部品を配置する事ができます。
 * <br />
 * 余白の設定は、<a href="#setMarginTop">setMarginTop</a> ( int margin ) 関数や <a href="#setMarginLeft">setMarginLeft</a> ( int margin ) 関数などで行います。
 * <br />
 * そして <a href="#getWindow">getWindow</a> ( ) 関数でウィンドウのIDを取得し、余白領域にGUI部品を自由に配置してください。
 * </p>
 *
 * <p>・フレームレート調整</p>
 *
 * <p>
 * 加えて、Graphics2DFramework は、フレームレートの自動調整機構も備えています。
 * <br />
 * 具体的には、Graphics2DFramework は、毎フレーム間の所要時間を計測し、常に設定された目標フレームレートに近づくよう、アニメーションループのウェイト ( 待機時間 ) を自動調整します。
 * <br />
 * 目標フレームレートは <a href="#setFrameRate">setFrameRate</a> ( float rate ) で設定します。
 * また、実測フレームレートは <a href="#getCurrentFrameRate">getCurrentFrameRate</a> ( ) で取得可能です。
 * </p>
 *
 * <p>・処理落ち</p>
 *
 * <p>
 * なお、実行環境の処理速度にも依存しますが、描画する画面サイズが大きかったり、描画内容が重かったりすると、
 * <br />
 * アニメーションの待機時間を最小にしても、実測フレームレートが目標フレームレートに達しなくなる現象 ―― 処理落ち ―― が生じます。
 * </p>
 * <p>
 * 処理落ちが発生すると、画面の再描画処理が追いつかなくなり、画面がちらつく場合があります。
 * <br />
 * その場合は、目標フレームレートを実測フレームレートの限界よりも余裕のある値に設定する事で、画面のちらつきを抑える事ができます。
 * <br />
 * しかし、実測フレームレートは環境に大きく依存するため、
 * 代わりに <a href="#setAnimationWaitMin">setAnimationWaitMin</a> ( int wait ) 関数でアニメーションウェイトの下限値（ミリ秒単位）を大きめに設定する事でも、
 * <br />
 * 画面のちらつきを抑える事ができます（ ただしこの場合、実測フレームレートの限界は低下します ）。
 * </p>
 *
 * @author  松井文宏 ( RINEARN )
 * @license Public domain ( CC0 )
 *
 * !--- locale=En-US ---
 * <p>
 * This library, graphics2d.Graphics2DFramework, is a lightweight framework for handling 2D computer graphics easily.
 * </p>
 *
 * <p>
 * When writing a 2D CG program from scratch using only the standard VCSSL libraries Graphics2D and GUI,
 * <br />
 * you need to write several fixed pieces of code every time, such as creating the window and renderer, the animation loop,
 * and basic event handlers.
 * <br />
 * Graphics2DFramework supports easy 2D CG development by preparing such fixed processing in advance as a framework template.
 * </p>
 *
 * <p>Required Processing</p>
 *
 * <p>
 * Structurally, Graphics2DFramework is already a complete 2D CG program by itself, and it can actually run as a standalone program.
 * <br />
 * However, by itself it has no drawing contents, so only a white screen is displayed.
 * </p>
 *
 * <p>
 * In practice, you import Graphics2DFramework from your own module and describe the required processing, such as placing and moving sprites.
 * <br />
 * Such processing is written by defining functions with specific names, just like event handlers for GUI components.
 * <br />
 * Then Graphics2DFramework automatically executes those event handler functions at appropriate timings.
 * </p>
 *
 * <p>
 * Graphics2DFramework automatically executes the following event handler functions. Their definitions are optional, so define only the ones you need.
 * <ul>
 *   <li>void onStart( int renderer ) - Executed only once at startup. Write initialization processing such as creating and placing sprites here. The old name initialize is also supported.</li>
 *   <li>void onExit( int renderer ) - Executed only once at shutdown. Write any shutdown processing here if needed. The old name finalize is also supported.</li>
 *   <li>void onPaint( int renderer ) - Executed every time the screen is updated, usually dozens of times per second. Write processing here when you want to draw 2D CG contents directly for animation. The old name paint is also supported.</li>
 *   <li>void onUpdate( int renderer ) - Executed every time between screen updates, usually dozens of times per second. Write processing here when you want to move sprites and so on. The old name update is also supported.</li>
 *   <li>void onResize( int renderer ) - Executed when the window size changes. Write processing here when you want to adjust the layout of GUI components placed on the screen. The old name resize is also supported.</li>
 * </ul>
 * In all of the above functions, the argument renderer receives the ID of the 2D CG renderer. Use it for drawing and for registering sprites.
 * </p>
 *
 * <p>Window Customization</p>
 *
 * <p>
 * Graphics2DFramework allows margin areas to be set inside the window, where GUI components such as buttons and text fields can be placed.
 * <br />
 * Margins can be configured with functions such as <a href="#setMarginTop">setMarginTop</a> ( int margin ) and <a href="#setMarginLeft">setMarginLeft</a> ( int margin ).
 * <br />
 * Then obtain the window ID by <a href="#getWindow">getWindow</a> ( ) and place GUI components freely in the margin areas.
 * </p>
 *
 * <p>Frame Rate Adjustment</p>
 *
 * <p>
 * Graphics2DFramework also has an automatic frame rate adjustment mechanism.
 * <br />
 * Specifically, it measures the time required for each frame and automatically adjusts the wait time of the animation loop so that the measured frame rate approaches the configured target frame rate.
 * <br />
 * Set the target frame rate with <a href="#setFrameRate">setFrameRate</a> ( float rate ).
 * The measured frame rate can be obtained with <a href="#getCurrentFrameRate">getCurrentFrameRate</a> ( ).
 * </p>
 *
 * <p>Slowdown</p>
 *
 * <p>
 * Depending on the processing speed of the execution environment, if the drawing area is large or the drawing contents are heavy,
 * <br />
 * the measured frame rate may fail to reach the target frame rate even when the animation wait time is minimized. This phenomenon is a slowdown.
 * </p>
 * <p>
 * When a slowdown occurs, screen repainting may fail to keep up and the display may flicker.
 * <br />
 * In that case, flicker can be reduced by setting the target frame rate to a value with enough margin below the measured frame rate limit.
 * <br />
 * However, because the measured frame rate depends heavily on the environment,
 * flicker can also be reduced by setting a relatively large lower limit for the animation wait time in milliseconds with <a href="#setAnimationWaitMin">setAnimationWaitMin</a> ( int wait ).
 * <br />
 * Note that this lowers the upper limit of the measured frame rate.
 * </p>
 *
 * @author  Fumihiro Matsui ( RINEARN )
 * @license Public domain ( CC0 )
 */


/**
 * !--- locale=Ja-JP ---
 * 2DCGのグラフィックスIDです。
 *
 * !--- locale=En-US ---
 * The graphics ID of the 2D CG graphics.
 */
private int graphics = -1;

/**
 * !--- locale=Ja-JP ---
 * 2DCGのグラフィックスIDを返します。
 *
 * @return 2DCGのグラフィックスID
 *
 * !--- locale=En-US ---
 * Returns the graphics ID of the 2D CG resource.
 *
 * @return The graphics ID of the 2D CG graphics.
 */
public int getGraphics(){
	return graphics;
}


/**
 * !--- locale=Ja-JP ---
 * 2DCGのレンダラーIDです。
 *
 * !--- locale=En-US ---
 * The renderer ID of the 2D CG renderer.
 */
private int renderer = -1;

/**
 * !--- locale=Ja-JP ---
 * 2DCGのレンダラーIDを返します。
 *
 * @return 2DCGのレンダラーID
 *
 * !--- locale=En-US ---
 * Returns the renderer ID of the 2D CG renderer.
 *
 * @return The renderer ID of the 2D CG renderer.
 */
public int getRenderer(){
	return renderer;
}


/**
 * !--- locale=Ja-JP ---
 * 描画内容を表示する、画像ラベルのGUIコンポーネントIDです。
 *
 * !--- locale=En-US ---
 * The GUI component ID of the image label displaying the drawing contents.
 */
private int imageLabel = -1;

/**
 * !--- locale=Ja-JP ---
 * 描画内容を表示する、画像ラベルのGUIコンポーネントIDを返します。
 *
 * @return 画像ラベルのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * Returns the GUI component ID of the image label displaying the drawing contents.
 *
 * @return The GUI component ID of the image label.
 */
public int getImageLabel(){
	return imageLabel;
}

/**
 * !--- locale=Ja-JP ---
 * 画像ラベルのGUIコンポーネントIDを返します。
 * この関数には、より新しい <a href="#getImageLabel">getImageLabel</a> がサポートされています。
 * この関数は互換目的でサポートされています。
 *
 * @return 描画領域ラベルのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * Returns the GUI component ID of the image label.
 * The newer <a href="#getImageLabel">getImageLabel</a> function is available for this purpose.
 * This function is supported for compatibility.
 *
 * @return The GUI component ID of the drawing area label.
 */
public int getGraphicsLabel(){
	return imageLabel;
}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウのGUIコンポーネントIDです。
 *
 * !--- locale=En-US ---
 * The GUI component ID of the window.
 */
private int window = -1;

/**
 * !--- locale=Ja-JP ---
 * ウィンドウのGUIコンポーネントIDを返します。
 *
 * @return ウィンドウのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * Returns the GUI component ID of the window.
 *
 * @return The GUI component ID of the window.
 */
public int getWindow(){
	return window;
}


/**
 * !--- locale=Ja-JP ---
 * アニメーションモードの有効/無効を制御する変数です。
 *
 * !--- locale=En-US ---
 * The variable controlling whether animation mode is enabled.
 */
private bool animation = true;


/**
 * !--- locale=Ja-JP ---
 * アニメーションモードの有効/無効を設定します。
 *
 * @param enable アニメーションモードの有効/無効(trueならば有効)
 *
 * !--- locale=En-US ---
 * Sets whether animation mode is enabled.
 *
 * @param enable Whether animation mode is enabled. It is enabled when true.
 */
public void setAnimationState(bool enable){
	animation = enable;
}

/**
 * !--- locale=Ja-JP ---
 * アニメーションの有効/無効を取得します。
 *
 * @return アニメーションモード有効/無効(trueならば有効)
 *
 * !--- locale=En-US ---
 * Gets whether animation mode is enabled.
 *
 * @return Whether animation mode is enabled. It is enabled when true.
 */
public bool getAnimationState(){
	return animation;
}



/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）の設定値です。
 *
 * !--- locale=En-US ---
 * The configured screen update frequency of the animation, that is, the number of redraws per second.
 */
private float frameRate = 30;

/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）を設定します。
 *
 * @param rate 画面更新頻度
 *
 * !--- locale=En-US ---
 * Sets the screen update frequency of the animation, that is, the number of redraws per second.
 *
 * @param rate The screen update frequency.
 */
public void setFrameRate(float rate){
	frameRate = rate;
}

/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）の設定値を取得します。
 *
 * @return 画面更新頻度(設定値)
 *
 * !--- locale=En-US ---
 * Gets the configured screen update frequency of the animation, that is, the number of redraws per second.
 *
 * @return The configured screen update frequency.
 */
public float getFrameRate(){
	return frameRate;
}


/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）の実測値です。
 *
 * !--- locale=En-US ---
 * The measured screen update frequency of the animation, that is, the number of redraws per second.
 */
private float currentFrameRate = frameRate;

/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）の実測値を取得します。
 *
 * @return 画面更新頻度(実測値)
 *
 * !--- locale=En-US ---
 * Gets the measured screen update frequency of the animation, that is, the number of redraws per second.
 *
 * @return The measured screen update frequency.
 */
public float getCurrentFrameRate(){
	return currentFrameRate;
}


/**
 * !--- locale=Ja-JP ---
 * アニメーションの最終画面更新時刻です。
 *
 * !--- locale=En-US ---
 * The time of the last screen update of the animation.
 */
private int lastFrameTime = 0;

/**
 * !--- locale=Ja-JP ---
 * アニメーションの最終画面更新時刻を取得します。
 * 時刻は、プログラム開始時刻からの経過時間を、通常はミリ秒単位で表したものが返されます。
 * ただし単位は処理系によって異なる可能性があります。
 * 処理系の依存性を完全に排除するためには、Time.millisecond関数を挟んで使用して下さい。
 *
 * @return 最終画面更新時刻(通常はミリ秒単位)
 *
 * !--- locale=En-US ---
 * Gets the time of the last screen update of the animation.
 * The returned time usually represents the elapsed time from program startup in milliseconds.
 * However, the unit may differ depending on the implementation.
 * To eliminate implementation dependence completely, convert it through the Time.millisecond function before using it.
 *
 * @return The time of the last screen update, usually in milliseconds.
 */
public int getLastFrameTime(){
	return lastFrameTime;
}


/**
 * !--- locale=Ja-JP ---
 * 画面描画時（paintコール前）に、自動でGraphics2D.paintGraphics2Dをコールするかどうかを制御する変数です。
 *
 * !--- locale=En-US ---
 * The variable controlling whether Graphics2D.paintGraphics2D is called automatically when the screen is drawn, before the paint call.
 */
private bool paintGraphics2DState = true;

/**
 * !--- locale=Ja-JP ---
 * 画面描画時（paintコール前）に、自動でGraphics2D.paintGraphics2Dをコールするかどうかを設定します。
 * trueを指定すると自動でコールされます。
 * falseに設定すると自動でコールされないので、paintイベントハンドラなどで明示的にコールする必要があります。
 *
 * @param state 設定した状態
 *
 * !--- locale=En-US ---
 * Sets whether Graphics2D.paintGraphics2D is called automatically when the screen is drawn, before the paint call.
 * If true is specified, it is called automatically.
 * If false is set, it is not called automatically, so it needs to be called explicitly in the paint event handler or elsewhere.
 *
 * @param state The state to set.
 */
public void setPaintGraphics2DState(bool b){
	paintGraphics2DState = b;
}

/**
 * !--- locale=Ja-JP ---
 * 画面描画時（paintコール前）に、自動でGraphics2D.paintGraphics2Dをコールするかどうかを取得します。
 *
 * @return 取得した状態
 *
 * !--- locale=En-US ---
 * Gets whether Graphics2D.paintGraphics2D is called automatically when the screen is drawn, before the paint call.
 *
 * @return The obtained state.
 */
public bool getPaintGraphics2DState(){
	return paintGraphics2DState;
}


/**
 * !--- locale=Ja-JP ---
 * 背景色の赤成分です。
 *
 * !--- locale=En-US ---
 * The red component of the background color.
 */
private int backgroundRed = 255;

/**
 * !--- locale=Ja-JP ---
 * 背景色の緑成分です。
 *
 * !--- locale=En-US ---
 * The green component of the background color.
 */
private int backgroundGreen = 255;

/**
 * !--- locale=Ja-JP ---
 * 背景色の青成分です。
 *
 * !--- locale=En-US ---
 * The blue component of the background color.
 */
private int backgroundBlue = 255;

/**
 * !--- locale=Ja-JP ---
 * 背景色のα成分です。
 *
 * !--- locale=En-US ---
 * The alpha component of the background color.
 */
private int backgroundAlpha = 255;

/**
 * !--- locale=Ja-JP ---
 * 背景色を設定します。引数には、背景色の 赤,緑,青,α成分 を、0～255の範囲で指定します。
 *
 * @param r 背景色(赤、0～255)
 * @param g 背景色(緑、0～255)
 * @param b 背景色(青、0～255)
 * @param a 背景色(α成分、0～255)
 *
 * !--- locale=En-US ---
 * Sets the background color. Specify the red, green, blue, and alpha components of the background color in the range from 0 to 255.
 *
 * @param r The red component of the background color, from 0 to 255.
 * @param g The green component of the background color, from 0 to 255.
 * @param b The blue component of the background color, from 0 to 255.
 * @param a The alpha component of the background color, from 0 to 255.
 */
public void setBackgroundColor(int r, int g, int b, int a){
	backgroundRed = r;
	backgroundGreen = g;
	backgroundBlue = b;
	backgroundAlpha = a;
	if(0 <= graphics){
		setGraphics2DColor(renderer, backgroundRed, backgroundGreen, backgroundBlue, backgroundAlpha);
	}
}

/**
 * !--- locale=Ja-JP ---
 * 背景色を設定します。引数には、背景色の 赤,緑,青,α成分 を、0～255の範囲で格納した配列を指定します。
 *
 * @param color 背景色配列([0]=赤、[1]=緑、[2]=青、[3]=α成分、各0～255)
 *
 * !--- locale=En-US ---
 * Sets the background color. Specify an array storing the red, green, blue, and alpha components of the background color in the range from 0 to 255.
 *
 * @param color The background color array, where [0]=red, [1]=green, [2]=blue, and [3]=alpha, each in the range from 0 to 255.
 */
public void setBackgroundColor(int color[]){
	backgroundRed = color[0];
	backgroundGreen = color[1];
	backgroundBlue = color[2];
	backgroundAlpha = color[3];
	if(0 <= graphics){
		setGraphics2DColor(renderer, backgroundRed, backgroundGreen, backgroundBlue, backgroundAlpha);
	}
}

/**
 * !--- locale=Ja-JP ---
 * 背景色を取得します。戻り値には、背景色の 赤,緑,青,α成分 を、0～255の範囲で格納した配列が返されます。
 *
 * @return 背景色配列([0]=赤、[1]=緑、[2]=青、[3]=α成分、各0～255)
 *
 * !--- locale=En-US ---
 * Gets the background color. The returned value is an array storing the red, green, blue, and alpha components of the background color in the range from 0 to 255.
 *
 * @return The background color array, where [0]=red, [1]=green, [2]=blue, and [3]=alpha, each in the range from 0 to 255.
 */
public int[] getBackgroundColor(){
	int color[] = {backgroundRed, backgroundGreen, backgroundBlue, backgroundAlpha};
	return color;
}



/**
 * !--- locale=Ja-JP ---
 * ウィンドウタイトルです。
 *
 * !--- locale=En-US ---
 * The window title.
 */
private string windowTitle = "Graphics2D Window";

/**
 * !--- locale=Ja-JP ---
 * ウィンドウタイトルを設定します。
 *
 * !--- locale=En-US ---
 * Sets the window title.
 */
public void setWindowTitle(string title){
	windowTitle = title;
	if(window != NULL){
		setComponentText(window, title);
	}
}

/**
 * !--- locale=Ja-JP ---
 * ウィンドウタイトルを取得します。
 *
 * !--- locale=En-US ---
 * Gets the window title.
 */
public string getWindowTitle(){
	return windowTitle;
}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウの幅です。
 *
 * !--- locale=En-US ---
 * The width of the window.
 */
private int windowWidth = 800;

/**
 * !--- locale=Ja-JP ---
 * ウィンドウの高さです。
 *
 * !--- locale=En-US ---
 * The height of the window.
 */
private int windowHeight = 600;

/**
 * !--- locale=Ja-JP ---
 * ウィンドウのX位置です。
 *
 * !--- locale=En-US ---
 * The X position of the window.
 */
private int windowX = 0;

/**
 * !--- locale=Ja-JP ---
 * ウィンドウのY位置です。
 *
 * !--- locale=En-US ---
 * The Y position of the window.
 */
private int windowY = 0;

/**
 * !--- locale=Ja-JP ---
 * ウィンドウサイズを設定します。
 *
 * @param width 幅
 * @param height 高さ
 *
 * !--- locale=En-US ---
 * Sets the window size.
 *
 * @param width The width.
 * @param height The height.
 */
public void setWindowSize(int width, int height){
	windowWidth = width;
	windowHeight = height;
	if(window != NULL){
		setComponentSize(window, windowWidth, windowHeight);
		sleep(windowResizeWait);
		setLayout();
	}
}

/**
 * !--- locale=Ja-JP ---
 * ウィンドウサイズを設定します。
 *
 * @param size ウィンドウサイズ（[0]=幅、[1]=高さ）
 *
 * !--- locale=En-US ---
 * Sets the window size.
 *
 * @param size The window size, where [0]=width and [1]=height.
 */
public void setWindowSize(int size[]){
	windowWidth = size[0];
	windowHeight = size[1];
	if(window != NULL){
		setComponentSize(window, windowWidth, windowHeight);
		setLayout();
	}
}

/**
 * !--- locale=Ja-JP ---
 * ウィンドウサイズを取得します。
 *
 * @return ウィンドウサイズ（[0]=幅、[1]=高さ）
 *
 * !--- locale=En-US ---
 * Gets the window size.
 *
 * @return The window size, where [0]=width and [1]=height.
 */
public int[] getWindowSize(){
	int size[] = {windowWidth, windowHeight};
	return size;
}


