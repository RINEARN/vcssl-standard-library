/**
 * !--- locale=Ja-JP ---
 * ウィンドウリサイズ後の待機時間
 *
 * !--- locale=En-US ---
 * The wait time after the window is resized.
 */
private int windowResizeWait = 100;

/**
 * !--- locale=Ja-JP ---
 * アニメーションウェイト（メインループのウェイト）の下限値を設定します。
 *
 * !--- locale=En-US ---
 * Sets the lower limit of the animation wait time, that is, the wait time of the main loop.
 */
public void setAnimationWaitMin(int wait){
	mainLoopWaitMin = wait;
}

/**
 * !--- locale=Ja-JP ---
 * アニメーションウェイト（メインループのウェイト）の下限値を設定します。
 *
 * !--- locale=En-US ---
 * Sets the lower limit of the animation wait time, that is, the wait time of the main loop.
 */
public int getAnimationWaitMin(){
	return mainLoopWaitMin;
}

/**
 * !--- locale=Ja-JP ---
 * アニメーションウェイト（メインループのウェイト）の上限値を設定します。
 *
 * !--- locale=En-US ---
 * Sets the upper limit of the animation wait time, that is, the wait time of the main loop.
 */
public void setAnimationWaitMax(int wait){
	mainLoopWaitMax = wait;
}

/**
 * !--- locale=Ja-JP ---
 * アニメーションウェイト（メインループのウェイト）の上限値を設定します。
 *
 * !--- locale=En-US ---
 * Sets the upper limit of the animation wait time, that is, the wait time of the main loop.
 */
public int getAnimationWaitMax(){
	return mainLoopWaitMax;
}

