/**
 * !--- locale=Ja-JP ---
 * メインループの継続状態を制御する変数です。
 *
 * !--- locale=En-US ---
 * The variable controlling whether the main loop continues.
 */
private bool mainLoopState = true;

/**
 * !--- locale=Ja-JP ---
 * メインループウェイトです。
 *
 * !--- locale=En-US ---
 * The main loop wait time.
 */
private int mainLoopWait;

/**
 * !--- locale=Ja-JP ---
 * メインループウェイトの下限値です。
 *
 * !--- locale=En-US ---
 * The lower limit of the main loop wait time.
 */
private int mainLoopWaitMin = 15;

/**
 * !--- locale=Ja-JP ---
 * メインループウェイトの上限値です。
 *
 * !--- locale=En-US ---
 * The upper limit of the main loop wait time.
 */
