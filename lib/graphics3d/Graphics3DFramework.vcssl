/**
 * !--- locale=Ja-JP ---
 * 画像ファイルの出力ファイルフォーマットです。
 *
 * !--- locale=En-US ---
 * The output file format of the image file.
 */
private string exportFormat = NULL;

/**
 * !--- locale=Ja-JP ---
 * 画像ファイルの出力品質です。
 *
 * !--- locale=En-US ---
 * The output quality of the image file.
 */
private float exportQuality = 0.0;


/**
 * !--- locale=Ja-JP ---
 * 現在の描画ラベルの内容を、画像ファイルに出力します。
 * ファイルの出力は、この関数をコールした瞬間に行われるわけでは無く、
 * 次回の画面更新タイミングに合わせて実行されます。
 *
 * @param filePath 出力ファイル名またはファイルパス
 * @param format ファイル形式（"PNG"または"JPEG"）
 * @param quality 品質
 *
 * !--- locale=En-US ---
 * Outputs the current contents of the drawing label as an image file.
 * File output is not performed at the moment this function is called.
 * It is executed at the next screen update timing.
 *
 * @param filePath The output file name or file path.
 * @param format The file format, either "PNG" or "JPEG".
 * @param quality The quality.
 */
public void export( string filePath, string format, float quality ){
	if(animation){
		exportFilePath = filePath;
		exportFormat = format;
		exportQuality = quality;
		exportRequested = true;
	}else{
		export();
	}
}


/**
 * !--- locale=Ja-JP ---
 * 現在の描画ラベルの内容を、画像ファイルに出力します。
 * 適切なタイミングで、メインループから実行されます。
 *
 * !--- locale=En-US ---
 * Outputs the current contents of the drawing label as an image file.
 * It is executed from the main loop at an appropriate timing.
 */
private void export(){
	if(backgroundRendererState){
		exportGraphics( backgroundGraphics, exportFilePath, exportFormat, exportQuality );
	}else{
		exportGraphics( graphics, exportFilePath, exportFormat, exportQuality );
	}
}


/**
 * !--- locale=Ja-JP ---
 * main関数です。通常は自動で実行され、frameworkMain関数をコールします。
 * ただし、メインプログラムでmain関数を定義する場合は、
 * こちらは自動で実行されなくなるので、
 * 下記のframeworkMainを明示的に呼ぶ必要があります。
 *
 * @param args メイン引数（ getMainArgument関数で取得可能 ）
 *
 * !--- locale=En-US ---
 * The main function. It is normally executed automatically and calls the frameworkMain function.
 * However, if the main program defines the main function,
 * this function is no longer executed automatically, so
 * the frameworkMain function below needs to be called explicitly.
 *
 * @param args The main arguments, which can also be obtained with the getMainArgument function.
 */
public void main( string args[] ){

	frameworkMain( args );

}


/**
 * !--- locale=Ja-JP ---
 * onPaint関数が定義されているかどうかを保持します。
 *
 * !--- locale=En-US ---
 * Stores whether the onPaint function is defined.
 */
private bool existsOnPaint = false;

/**
 * !--- locale=Ja-JP ---
 * onUpdate関数が定義されているかどうかを保持します。
 *
 * !--- locale=En-US ---
 * Stores whether the onUpdate function is defined.
 */
private bool existsOnUpdate = false;

/**
 * !--- locale=Ja-JP ---
 * onStart関数が定義されているかどうかを保持します。
 *
 * !--- locale=En-US ---
 * Stores whether the onStart function is defined.
 */
private bool existsOnStart = false;

/**
 * !--- locale=Ja-JP ---
 * onExit関数が定義されているかどうかを保持します。
 *
 * !--- locale=En-US ---
 * Stores whether the onExit function is defined.
 */
private bool existsOnExit = false;

/**
 * !--- locale=Ja-JP ---
 * onResize関数が定義されているかどうかを保持します。
 *
 * !--- locale=En-US ---
 * Stores whether the onResize function is defined.
 */
private bool existsOnResize = false;


/**
 * !--- locale=Ja-JP ---
 * 各種コールバック関数が定義されているかを検証します。
 *
 * !--- locale=En-US ---
 * Verifies whether the callback functions are defined.
 */
private void checkCallback(){
	existsOnPaint = evaluable("onPaint(renderer)");
	existsOnUpdate = evaluable("onUpdate(renderer)");
	existsOnStart = evaluable("onStart(renderer)");
	existsOnExit = evaluable("onExit(renderer)");
	existsOnResize = evaluable("onResize(renderer)");
}


/**
 * !--- locale=Ja-JP ---
 * フレームワークのリソースを初期化する処理です。
 * この関数は、このフレームワークのプログラムの末尾、
 * グローバル領域においてコールされます。
 * 従って、このフレームワークを
 * import しているプログラムのグローバル領域実行時には、
 * すでにリソースが確保されている事が保証されます。
 *
 * !--- locale=En-US ---
 * Initializes the framework resources.
 * This function is called at the end of this framework program,
 * in the global scope.
 * Therefore, when a program importing this framework
 * executes its global scope,
 * the resources are already guaranteed to have been allocated.
 */
private void frameworkInitialize() {
	initializeWindow();
	initializeGraphics();
	initializeComponent();
}



/**
 * !--- locale=Ja-JP ---
 * フレームワークのメイン処理です。通常はmain関数から自動で実行されます。
 * ただし、メインプログラムでmain関数を定義する場合は、
 * 自動で実行されなくなるので、適当なタイミングで呼ぶ必要があります。
 *
 * @param args メイン引数（ getMainArgument関数で取得可能 ）
 *
 * !--- locale=En-US ---
 * The main processing of the framework. It is normally executed automatically from the main function.
 * However, if the main program defines the main function,
 * it is no longer executed automatically, so it needs to be called at an appropriate timing.
 *
 * @param args The main arguments, which can also be obtained with the getMainArgument function.
 */
public void frameworkMain( string args[] ){
	
	mainArguments = args;
	checkCallback();
	
	if( existsOnStart ){
		eval( "onStart( renderer )" );
	}
	
	if( paintGraphics3DState ){
		paintGraphics3D( renderer );
	}
	
	if( existsOnPaint ){
		eval( "onPaint( renderer )" );
	}
	
	paintWindow();
	
	mainLoopWait = 1000.0 / frameRate;
	mainLoopWaitMax = 1000.0 / frameRate;
	
	mainLoop();
	
	if( existsOnExit ){
		eval( "onExit( renderer )" );
	}
	
	exit();
}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウが閉じられた際にコールされるイベントハンドラです。
 *
 * @param id ウィンドウのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * The event handler called when the window is closed.
 *
 * @param id The GUI component ID of the window.
 */
public void onWindowClose( int id ){
	if( id == window ){
		mainLoopState = false;
	}
}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウがリサイズされた事をメインループに通知する変数です。
 *
 * !--- locale=En-US ---
 * The variable notifying the main loop that the window has been resized.
 */
private bool windowResized = false;


/**
 * !--- locale=Ja-JP ---
 * ウィンドウがリサイズされた際にコールされるイベントハンドラです。
 *
 * @param id ウィンドウのGUIコンポーネントID
 * @param width ウィンドウの幅
 * @param height ウィンドウの高さ
 *
 * !--- locale=En-US ---
 * The event handler called when the window is resized.
 *
 * @param id The GUI component ID of the window.
 * @param width The width of the window.
 * @param height The height of the window.
 */
public void onWindowResize( int id, int width, int height ){
	if( id == window ){
		if( width!=windowWidth || height!=windowHeight ){
			windowWidth = width;
			windowHeight = height;
			windowResized = true;
		}
	}

}


/**
 * !--- locale=Ja-JP ---
 * メインループです。
 * 毎秒 frameRate 回の頻度で、描画処理(paint)と更新処理(update)、
 * フレームレートの調整処理などを繰り返します。
 *
 * !--- locale=En-US ---
 * The main loop.
 * It repeats the drawing processing paint, the update processing update, and related processing
 * at the frequency of frameRate times per second.
 */
private void mainLoop(){

	setComponentColor(imageLabel, 0,0,0,255, 0,0,0,255);

	while( mainLoopState ){

		lastFrameTime = time();

		// ウィンドウがリサイズされた場合はここで修正
		if(windowResized){
			windowResized = false;
			sleep(windowResizeWait);
			setLayout();
		}

		if( animation ){

			if(existsOnUpdate){
				eval( "onUpdate( renderer )" );
			}

			// レンダリング
			render();

			// ファイル出力要求があればここで実行
			if(exportRequested){
				export();
				exportRequested = false;
			}

			paintWindow();

		}

		// アニメーションウェイト
		sleep( mainLoopWait );

		// フレームレート調整
		currentFrameRate = 1000.0 / millisecond(time()-(lastFrameTime));
		mainLoopWait = getLoopWait(
			frameRate, currentFrameRate, mainLoopWait, mainLoopWaitMin, mainLoopWaitMax
		);

	}

}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウの再描画を行います。
 * 通常は自動で実行されますが、
 * 通常は自動で実行されますが、アニメーションを無効にしている場合などは、
 * 画面更新時に明示的に呼び出す必要があります。
 *
 * !--- locale=En-US ---
 * Repaints the window.
 * It is normally executed automatically, but
 * It is normally executed automatically, but when animation is disabled and in similar cases,
 * it needs to be called explicitly when the screen is updated.
 */
public void paintWindow(){
	paintComponent( imageLabel );
	paintComponent( window );
}


/**
 * !--- locale=Ja-JP ---
 * paint関数などをコールし、画面表示内容を描画します。
 * 3DCGと、背景及び前景2DCGの合成も行います。
 * 通常は自動で実行されますが、アニメーションを無効にしている場合などは、
 * 画面更新時に明示的に呼び出す必要があります。
 *
 * !--- locale=En-US ---
 * Calls the paint function and related processing to render the screen contents.
 * It also composites the 3D CG contents with the background and foreground 2D CG contents.
 * It is normally executed automatically, but when animation is disabled and in similar cases,
 * it needs to be called explicitly when the screen is updated.
 */
public void render(){
	if(backgroundRendererState){
		if(foregroundRendererState){
			render3DAndBackgroundAndForeground();
		}else{
			render3DAndBackground();
		}
	}else{
		render3D();
	}
}


/**
 * !--- locale=Ja-JP ---
 * 3DCGのみを描画します。（背景及び前景2DCG無効時）
 *
 * @param existsPaint paint関数の有無
 *
 * !--- locale=En-US ---
 * Draws only the 3D CG contents when the background and foreground 2D CG renderers are disabled.
 *
 * @param existsPaint Whether the paint function exists.
 */
private void render3D(){
	setRendererBackgroundColor();
	if( paintGraphics3DState ){
		paintGraphics3D( renderer );
	}
	if(existsOnPaint){
		eval( "onPaint( renderer )" );
	}
}


/**
 * !--- locale=Ja-JP ---
 * 3DCGと背景2DCGを描画します。（前景2DCGのみ無効時）
 *
 * !--- locale=En-US ---
 * Draws the 3D CG contents and the background 2D CG contents when only the foreground 2D CG renderer is disabled.
 */
private void render3DAndBackground(){
	setRendererBackgroundColor();
	if( paintGraphics2DState ){
		paintGraphics2D( backgroundRenderer );
	}
	if( paintGraphics3DState ){
		paintGraphics3D( renderer );
	}
	if(existsOnPaint){
		eval( "onPaint( renderer )" );
	}
	drawGraphics(backgroundRenderer, 0, 0, graphics);
}

/**
 * !--- locale=Ja-JP ---
 * 3DCGと、背景及び前景2DCGを描画します。（全レンダラ有効時）
 *
 * !--- locale=En-US ---
 * Draws the 3D CG contents together with the background and foreground 2D CG contents when all renderers are enabled.
 */
private void render3DAndBackgroundAndForeground(){
	setRendererBackgroundColor();
	if( paintGraphics2DState ){
		paintGraphics2D( foregroundRenderer );
		paintGraphics2D( backgroundRenderer );
	}
	if( paintGraphics3DState ){
		paintGraphics3D( renderer );
	}
	if(existsOnPaint){
		eval( "onPaint( renderer )" );
	}
	drawGraphics(backgroundRenderer, 0, 0, graphics);
	drawGraphics(backgroundRenderer, 0, 0, foregroundGraphics);
}


/**
 * !--- locale=Ja-JP ---
 * 目標フレームレート、実測フレームレート、
 * 現在のループウェイトなどから、次フレームでの最適なループウェイトを計算して返します。
 *
 * !--- locale=En-US ---
 * The target frame rate, the measured frame rate,
 * Calculates and returns the optimal loop wait time for the next frame from the current loop wait time and related values.
 */
private int getLoopWait( float targetFrameRate, float currentFrameRate, int currentLoopWait, int limitMin, int limitMax ){
	if( targetFrameRate > currentFrameRate ){
		if( limitMin < currentLoopWait ){
			currentLoopWait--;
		}else{
			currentLoopWait++;
		}
	}else{
		if( limitMax > currentLoopWait ){
			currentLoopWait++;
		}else{
			currentLoopWait--;
		}
	}
	return currentLoopWait;
}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウの生成と初期化を行います。
 *
 * !--- locale=En-US ---
 * Creates and initializes the window.
 */
private void initializeWindow(){
	window = newWindow( windowX, windowY, windowWidth, windowHeight, windowTitle );
	sleep(windowResizeWait);
}


/**
 * !--- locale=Ja-JP ---
 * グラフィックスリソース関連の確保と初期化を行います。
 *
 * !--- locale=En-US ---
 * Allocates and initializes graphics-related resources.
 */
private void initializeGraphics(){

	int labelWidth = getPreferredScreenWidth();
	int labelHeight = getPreferredScreenHeight();

	graphics = newGraphics();
	renderer = newGraphics3DRenderer( labelWidth, labelHeight, graphics );

	setGraphics3DColor( renderer, backgroundRed, backgroundGreen, backgroundBlue, backgroundAlpha );

	setGraphics3DMagnification( renderer, magnification );

	light = newLight( lightX, lightY, lightZ, lightPower ) ;
	mountLight( light, renderer );

	ambientLight = newAmbientLight( ambientLightX, ambientLightY, ambientLightZ, ambientLightPower ) ;
	mountLight( ambientLight, renderer );

}


/**
 * !--- locale=Ja-JP ---
 * GUIコンポーネント関連の確保と初期化を行います。
 *
 * !--- locale=En-US ---
 * Allocates and initializes GUI-related components.
 */
private void initializeComponent(){

	int labelWidth = getPreferredScreenWidth();
	int labelHeight = getPreferredScreenHeight();

	imageLabel = newGraphicsLabel( marginLeft, marginTop, labelWidth, labelHeight, graphics );
	setGraphicsLabelRenderer();

	mountComponent( imageLabel, window );

	setGraphics3DDefaultEventHandler( renderer, imageLabel );

}


/**
 * !--- locale=Ja-JP ---
 * レイアウトを再計算してGUI配置を調整します。
 *
 * !--- locale=En-US ---
 * Recalculates the layout and adjusts the GUI arrangement.
 */
private void setLayout(){

	int labelWidth = getPreferredScreenWidth();
	int labelHeight = getPreferredScreenHeight();

	setComponentLocation( imageLabel, marginLeft, margin Top );
	setComponentSize( imageLabel, labelWidth, labelHeight );
	setGraphics3DSize( renderer, labelWidth, labelHeight );

	if(backgroundRenderer != NULL){
		setGraphics2DSize( backgroundRenderer, labelWidth, labelHeight );
	}
	if(foregroundRenderer != NULL){
		setGraphics2DSize( foregroundRenderer, labelWidth, labelHeight );
	}
	
	if( existsOnResize ){
		eval( "onResize( renderer )" );
	}
}


/**
 * !--- locale=Ja-JP ---
 * 描画ラベルにレンダラーを関連付けます。
 *
 * !--- locale=En-US ---
 * Associates the renderer with the drawing label.
 */
private void setGraphicsLabelRenderer(){
	if(imageLabel == NULL){
		return;
	}
	if(backgroundRendererState){
		setComponentGraphics(imageLabel, backgroundGraphics);
	}else{
		setComponentGraphics(imageLabel, graphics);
	}
}


/**
 * !--- locale=Ja-JP ---
 * 適切な描画領域の幅を返します。
 *
 * !--- locale=En-US ---
 * Returns the appropriate width of the drawing area.
 */
private int getPreferredScreenWidth(){
	int innerSize[] = getComponentSize(window, GUI.INNER);
	int labelWidth = innerSize[0] - marginRight - marginLeft;
	return labelWidth;
}


/**
 * !--- locale=Ja-JP ---
 * 適切な描画領域の高さを返します。
 *
 * !--- locale=En-US ---
 * Returns the appropriate height of the drawing area.
 */
private void getPreferredScreenHeight(){
	int innerSize[] = getComponentSize(window, GUI.INNER);
	int labelHeight = innerSize[1] - marginTop - marginBottom;
	return labelHeight;
}


// リソースを確保します。このように、グローバル領域でこの処理を実行する理由は、このフレームワークを import しているプログラムのグローバル領域実行時において、すでにリソースが確保されている事を保証するためです。
frameworkInitialize();

