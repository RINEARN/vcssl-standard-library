 *
 * @param v The array of vector components, where v[0]=X, v[1]=Y, and v[2]=Z.
 */
void setDirectionalLightVector(float v[]){
	if(light != NULL){
		lightX = v[0];
		lightY = v[1];
		lightZ = v[2];
		Graphics3D.setLightVector(light, lightX, lightY, lightZ);
	}
}

