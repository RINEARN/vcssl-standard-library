 * @param z The Z component.
 */
void setDirectionalLightVector(float x, float y, float z){
	if(light != NULL){
		lightX = x;
		lightY = y;
		lightZ = z;
		Graphics3D.setLightVector(light, lightX, lightY, lightZ);
	}
}

/**
