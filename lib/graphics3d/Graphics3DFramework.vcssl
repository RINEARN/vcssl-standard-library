coding UTF-8;

# PRAGMA COMPILE    REFERRAL
# PRAGMA RESERVE    ALL
# PRAGMA END

import GUI;
import Graphics;
import Graphics3D;
import Graphics2D;
import Time;

/**
 * !--- locale=Ja-JP ---
 * <p>
 * このライブラリ graphics3d.Graphics3DFramework は、
 * 3DCG（ 3次元グラフィックス ）を手軽に扱うための軽量フレームワークです。
 * </p>
 *
 * <p>
 * VCSSLの標準ライブラリ「 Graphics3D 」や「 GUI 」だけを用いて、ゼロから3DCGプログラムを記述する場合、
 * <br />
 * ウィンドウ・レンダラー（描画エンジン）の生成や、アニメーションループ、
 * 基本的なイベントハンドラなど、いくつかの定型的な処理を、毎回記述しなければいけません。
 * <br />
 * そこで、この Graphics3DFramework では、上述のような定型処理を、雛形のようにあらかじめ用意する事によって、手軽な3DCG利用をサポートします。
 * </p>
 *
 * <p>・必要な処理の記述</p>
 *
 * <p>
 * Graphics3DFramework は、構造的には、単体で既に完成した3DCGプログラムです。実際、単体で実行する事が可能です。
 * <br />
 * ただし、単体では何の3Dモデルも配置されておらず、ただ白い画面が表示されるだけです。
 * </p>
 *
 * <p>
 * そこで実際には、自作モジュールから Graphics3DFramework を import し、3Dモデルの配置や移動など、必要な処理を記述します。
 * <br />
 * そういった処理は、いくつかの決まった名前の関数を定義し、そこに記述します。つまり、GUIなどのイベントハンドラと同じ仕組みです。
 * <br />
 * するとそれらのイベントハンドラ関数を、Graphics3DFramework が適切なタイミングで自動実行します。
 * </p>
 *
 * <p>
 * Graphics3DFramework が自動実行するイベントハンドラ関数は、下記のものがあります。定義は必須では無いので、必要な関数だけを定義し、記述して下さい。
 * <ul>
 *   <li>void onStart( int renderer ) - 起動時に一度だけ実行されます。3Dモデルの生成・配置などの初期化処理は、ここに記述します。旧称 initialize も使用可能です。</li>
 *   <li>void onExit( int renderer ) - 終了時に一度だけ実行されます。終了時に行いたい処理があれば、ここに記述します。旧称 finalize も使用可能です。</li>
 *   <li>void onPaint( int renderer ) - 画面更新タイミング（毎秒数十回）で毎回実行されます。前景・背景2DCGの描画を行いたい場合などは、ここに記述します。旧称 paint も使用可能です。</li>
 *   <li>void onUpdate( int renderer ) - 画面更新タイミング（毎秒数十回）の間で毎回実行されます。3Dモデルの移動などを行いたい場合などは、ここに記述します。旧称 update も使用可能です。</li>
 *   <li>void onResize( int renderer ) - ウィンドウサイズが変更された場合に実行されます。画面に配置したGUI部品のレイアウト調整などを行いたい場合は、ここに記述します。旧称 resize も使用可能です。</li>
 * </ul>
 * 上記関数のいずれも、引数 renderer には、3DCGレンダラーのID が渡されます。これは3Dモデルの配置などに使用します。
 * </p>
 *
 * <p>・背景・前景の2DCG描画</p>
 *
 * <p>
 * Graphics3DFramework は、前景・背景の2DCG描画もサポートしています。
 * <br />
 * ただしこの機能はデフォルトで無効になっているため、利用する前にそれぞれ
 * <a href="#setForegroundRendererState">setForegroundRendererState</a> ( true ) 及び
 * <a href="#setBackgroundRendererState">setBackgroundRendererState</a> ( true ) を実行して下さい。
 * <br />
 * その後、
 * <a href="#getForegroundRenderer">getForegroundRenderer</a> ( ) 及び
 * <a href="#getBackgroundRenderer">getBackgroundRenderer</a> ( ) で 2DCGレンダラーのIDを取得し、onPaint関数内などで描画を行います。
 * </p>
 *
 * <p>・ウィンドウのカスタマイズ</p>
 *
 * <p>
 * Graphics3DFramework では、ウィンドウ内に余白領域を設定し、そこにボタンやテキストフィールドなどのGUI部品を配置する事ができます。
 * <br />
 * 余白の設定は、<a href="#setMarginTop">setMarginTop</a> ( int margin ) 関数や <a href="#setMarginLeft">setMarginLeft</a> ( int margin ) 関数などで行います。
 * <br />
 * そして <a href="#getWindow">getWindow</a> ( ) 関数でウィンドウのIDを取得し、余白領域にGUI部品を自由に配置してください。
 * </p>
 *
 * <p>・フレームレート調整</p>
 *
 * <p>
 * 加えて、Graphics3DFramework は、フレームレートの自動調整機構も備えています。
 * <br />
 * 具体的には、Graphics3DFramework は、毎フレーム間の所要時間を計測し、常に設定された目標フレームレートに近づくよう、アニメーションループのウェイト ( 待機時間 ) を自動調整します。
 * <br />
 * 目標フレームレートは <a href="#setFrameRate">setFrameRate</a> ( float rate ) で設定します。
 * また、実測フレームレートは <a href="#getCurrentFrameRate">getCurrentFrameRate</a> ( ) で取得可能です。
 * </p>
 *
 * <p>・処理落ち</p>
 *
 * <p>
 * なお、実行環境の処理速度にも依存しますが、描画する画面サイズが大きかったり、描画内容が重かったりすると、
 * <br />
 * アニメーションの待機時間を最小にしても、実測フレームレートが目標フレームレートに達しなくなる現象 ―― 処理落ち ―― が生じます。
 * </p>
 * <p>
 * 処理落ちが発生すると、画面の再描画処理が追いつかなくなり、画面がちらつく場合があります。
 * <br />
 * その場合は、目標フレームレートを実測フレームレートの限界よりも余裕のある値に設定する事で、画面のちらつきを抑える事ができます。
 * <br />
 * しかし、実測フレームレートは環境に大きく依存するため、
 * 代わりに <a href="#setAnimationWaitMin">setAnimationWaitMin</a> ( int wait ) 関数でアニメーションウェイトの下限値（ミリ秒単位）を大きめに設定する事でも、
 * <br />
 * 画面のちらつきを抑える事ができます（ ただしこの場合、実測フレームレートの限界は低下します ）。
 * </p>
 *
 * @author  松井文宏 ( RINEARN )
 * @license Public domain ( CC0 )
 *
 * !--- locale=En-US ---
 * <p>
 * This library, graphics3d.Graphics3DFramework, is a lightweight framework for handling 3D computer graphics easily.
 * </p>
 *
 * <p>
 * When writing a 3D CG program from scratch using only the standard VCSSL libraries Graphics3D and GUI,
 * <br />
 * you need to write several fixed pieces of code every time, such as creating the window and renderer, the animation loop,
 * and basic event handlers.
 * <br />
 * Graphics3DFramework supports easy 3D CG development by preparing such fixed processing in advance as a framework template.
 * </p>
 *
 * <p>Required Processing</p>
 *
 * <p>
 * Structurally, Graphics3DFramework is already a complete 3D CG program by itself, and it can actually run as a standalone program.
 * <br />
 * However, by itself no 3D models are placed, so only a white screen is displayed.
 * </p>
 *
 * <p>
 * In practice, you import Graphics3DFramework from your own module and describe the required processing, such as placing and moving 3D models.
 * <br />
 * Such processing is written by defining functions with specific names, just like event handlers for GUI components.
 * <br />
 * Then Graphics3DFramework automatically executes those event handler functions at appropriate timings.
 * </p>
 *
 * <p>
 * Graphics3DFramework automatically executes the following event handler functions. Their definitions are optional, so define only the ones you need.
 * <ul>
 *   <li>void onStart( int renderer ) - Executed only once at startup. Write initialization processing such as creating and placing 3D models here. The old name initialize is also supported.</li>
 *   <li>void onExit( int renderer ) - Executed only once at shutdown. Write any shutdown processing here if needed. The old name finalize is also supported.</li>
 *   <li>void onPaint( int renderer ) - Executed every time the screen is updated, usually dozens of times per second. Write processing here when you want to draw foreground or background 2D CG contents. The old name paint is also supported.</li>
 *   <li>void onUpdate( int renderer ) - Executed every time between screen updates, usually dozens of times per second. Write processing here when you want to move 3D models and so on. The old name update is also supported.</li>
 *   <li>void onResize( int renderer ) - Executed when the window size changes. Write processing here when you want to adjust the layout of GUI components placed on the screen. The old name resize is also supported.</li>
 * </ul>
 * In all of the above functions, the argument renderer receives the ID of the 3D CG renderer. Use it for placing 3D models and related processing.
 * </p>
 *
 * <p>Background and Foreground 2D CG Drawing</p>
 *
 * <p>
 * Graphics3DFramework also supports foreground and background 2D CG drawing.
 * <br />
 * However, this feature is disabled by default, so before using it, call
 * <a href="#setForegroundRendererState">setForegroundRendererState</a> ( true ) and
 * <a href="#setBackgroundRendererState">setBackgroundRendererState</a> ( true ) respectively.
 * <br />
 * After that, obtain the IDs of the 2D CG renderers with
 * <a href="#getForegroundRenderer">getForegroundRenderer</a> ( ) and
 * <a href="#getBackgroundRenderer">getBackgroundRenderer</a> ( ), and perform drawing in functions such as onPaint.
 * </p>
 *
 * <p>Window Customization</p>
 *
 * <p>
 * Graphics3DFramework allows margin areas to be set inside the window, where GUI components such as buttons and text fields can be placed.
 * <br />
 * Margins can be configured with functions such as <a href="#setMarginTop">setMarginTop</a> ( int margin ) and <a href="#setMarginLeft">setMarginLeft</a> ( int margin ).
 * <br />
 * Then obtain the window ID by <a href="#getWindow">getWindow</a> ( ) and place GUI components freely in the margin areas.
 * </p>
 *
 * <p>Frame Rate Adjustment</p>
 *
 * <p>
 * Graphics3DFramework also has an automatic frame rate adjustment mechanism.
 * <br />
 * Specifically, it measures the time required for each frame and automatically adjusts the wait time of the animation loop so that the measured frame rate approaches the configured target frame rate.
 * <br />
 * Set the target frame rate with <a href="#setFrameRate">setFrameRate</a> ( float rate ).
 * The measured frame rate can be obtained with <a href="#getCurrentFrameRate">getCurrentFrameRate</a> ( ).
 * </p>
 *
 * <p>Slowdown</p>
 *
 * <p>
 * Depending on the processing speed of the execution environment, if the drawing area is large or the drawing contents are heavy,
 * <br />
 * the measured frame rate may fail to reach the target frame rate even when the animation wait time is minimized. This phenomenon is a slowdown.
 * </p>
 * <p>
 * When a slowdown occurs, screen repainting may fail to keep up and the display may flicker.
 * <br />
 * In that case, flicker can be reduced by setting the target frame rate to a value with enough margin below the measured frame rate limit.
 * <br />
 * However, because the measured frame rate depends heavily on the environment,
 * flicker can also be reduced by setting a relatively large lower limit for the animation wait time in milliseconds with <a href="#setAnimationWaitMin">setAnimationWaitMin</a> ( int wait ).
 * <br />
 * Note that this lowers the upper limit of the measured frame rate.
 * </p>
 *
 * @author  Fumihiro Matsui ( RINEARN )
 * @license Public domain ( CC0 )
 */


/**
 * !--- locale=Ja-JP ---
 * エラーメッセージ: 背景レンダラ無効時に使用しようとした場合
 *
 * !--- locale=En-US ---
 * The error message used when it is requested while the background renderer is disabled.
 */
private const string ERROR_BACKGROUND_RENDERER_IS_DISABLED = "The background renderer is required but it is disabled. 背景レンダラが要求されましたが、無効になっています。 setBackgroundRendererState(true); で有効にして下さい。";

/**
 * !--- locale=Ja-JP ---
 * エラーメッセージ: 前景レンダラ無効時に使用しようとした場合
 *
 * !--- locale=En-US ---
 * The error message used when it is requested while the foreground renderer is disabled.
 */
private const string ERROR_FOREGROUND_RENDERER_IS_DISABLED = "The foreground renderer is required but it is disabled. 前景レンダラが要求されましたが、無効になっています。 setForegroundRendererState(true); で有効にして下さい。";

/**
 * !--- locale=Ja-JP ---
 * エラーメッセージ: 背景レンダラ無効時に前景レンダラを有効にした場合
 *
 * !--- locale=En-US ---
 * The error message used when the foreground renderer is enabled while the background renderer is disabled.
 */
private const string ERROR_BACKGROUND_RENDERER_IS_DISABLED_AND_FOREGRAUND_RENDERER_IS_ENABLED = "It is necessary to enable the background renderer to enable the foreground renderer. 前景レンダラを使用するには、背景レンダラを有効にする必要がありますが、無効になっています。 setBackgroundRendererState(true) を実行して下さい。";


/**
 * !--- locale=Ja-JP ---
 * 3DCGのグラフィックスリソースIDです。
 *
 * !--- locale=En-US ---
 * The graphics resource ID of the 3D CG graphics.
 */
private int graphics = NULL;

/**
 * !--- locale=Ja-JP ---
 * 3DCGのグラフィックスリソースIDを返します。
 *
 * @return 3DCGのグラフィックスリソースID
 *
 * !--- locale=En-US ---
 * Returns the graphics resource ID of the 3D CG graphics.
 *
 * @return The graphics resource ID of the 3D CG graphics.
 */
public int getGraphics(){
	return graphics;
}


/**
 * !--- locale=Ja-JP ---
 * 背景2DCGのグラフィックスリソースIDです。
 *
 * !--- locale=En-US ---
 * The graphics resource ID of the background 2D CG graphics.
 */
private int backgroundGraphics = NULL;

/**
 * !--- locale=Ja-JP ---
 * 背景2DCGのグラフィックスリソースIDを返します。
 *
 * @return 背景2DCGのグラフィックスリソースID
 *
 * !--- locale=En-US ---
 * Returns the graphics resource ID of the background 2D CG graphics.
 *
 * @return The graphics resource ID of the background 2D CG graphics.
 */
public int getBackgroundGraphics(){
	return backgroundGraphics;
}


/**
 * !--- locale=Ja-JP ---
 * 前景2DCGのグラフィックスリソースIDです。
 *
 * !--- locale=En-US ---
 * The graphics resource ID of the foreground 2D CG graphics.
 */
private int foregroundGraphics = NULL;

/**
 * !--- locale=Ja-JP ---
 * 前景2DCGのグラフィックスリソースIDを返します。
 *
 * @return 前景2DCGのグラフィックスリソースID
 *
 * !--- locale=En-US ---
 * Returns the graphics resource ID of the foreground 2D CG graphics.
 *
 * @return The graphics resource ID of the foreground 2D CG graphics.
 */
public int getForegroundGraphics(){
	return foregroundGraphics;
}


/**
 * !--- locale=Ja-JP ---
 * 3DCGのレンダラーIDです。
 *
 * !--- locale=En-US ---
 * The renderer ID of the 3D CG renderer.
 */
private int renderer = NULL;

/**
 * !--- locale=Ja-JP ---
 * 3DCGのレンダラーIDを返します。
 *
 * @return 3DCGのレンダラーID
 *
 * !--- locale=En-US ---
 * Returns the renderer ID of the 3D CG renderer.
 *
 * @return The renderer ID of the 3D CG renderer.
 */
public int getRenderer(){
	return renderer;
}


/**
 * !--- locale=Ja-JP ---
 * 背景2DCGのレンダラーIDです。
 *
 * !--- locale=En-US ---
 * The renderer ID of the background 2D CG renderer.
 */
private int backgroundRenderer = NULL;

/**
 * !--- locale=Ja-JP ---
 * 背景2DCGのレンダラーIDを返します。
 *
 * @return 背景2DCGのレンダラーID
 *
 * !--- locale=En-US ---
 * Returns the renderer ID of the background 2D CG renderer.
 *
 * @return The renderer ID of the background 2D CG renderer.
 */
public int getBackgroundRenderer(){
	if(!backgroundRendererState){
		error(ERROR_BACKGROUND_RENDERER_IS_DISABLED);
		return NULL;
	}
	return backgroundRenderer;
}


/**
 * !--- locale=Ja-JP ---
 * 前景2DCGのレンダラーIDです。
 *
 * !--- locale=En-US ---
 * The renderer ID of the foreground 2D CG renderer.
 */
private int foregroundRenderer = NULL;

/**
 * !--- locale=Ja-JP ---
 * 前景2DCGのレンダラーIDを返します。
 *
 * @return 前景2DCGのレンダラーID
 *
 * !--- locale=En-US ---
 * Returns the renderer ID of the foreground 2D CG renderer.
 *
 * @return The renderer ID of the foreground 2D CG renderer.
 */
public int getForegroundRenderer(){
	if(!backgroundRendererState){
		error(ERROR_FOREGROUND_RENDERER_IS_DISABLED);
		return NULL;
	}
	return foregroundRenderer;
}


/**
 * !--- locale=Ja-JP ---
 * 背景2DCGレンダラーの有効/無効を制御する変数です。
 *
 * !--- locale=En-US ---
 * The variable controlling whether the background 2D CG renderer is enabled.
 */
private bool backgroundRendererState = false;

/**
 * !--- locale=Ja-JP ---
 * 背景2DCGレンダラーの有効/無効を設定します。
 *
 * @param state 背景2DCGレンダラーの有効/無効（trueならば有効）
 *
 * !--- locale=En-US ---
 * Sets whether the background 2D CG renderer is enabled.
 *
 * @param state Whether the background 2D CG renderer is enabled. It is enabled when true.
 */
public void setBackgroundRendererState(bool state){
	backgroundRendererState = state;
	if(backgroundGraphics == NULL){
		int width = getPreferredScreenWidth();
		int height = getPreferredScreenHeight();
		backgroundGraphics = newGraphics();
		backgroundRenderer = newGraphics2DRenderer( width, height, backgroundGraphics );
	}
	setGraphicsLabelRenderer();
}

/**
 * !--- locale=Ja-JP ---
 * 背景2DCGレンダラーの有効/無効を取得します。
 *
 * @return 背景2DCGレンダラーの有効/無効（trueならば有効）
 *
 * !--- locale=En-US ---
 * Gets whether the background 2D CG renderer is enabled.
 *
 * @return Whether the background 2D CG renderer is enabled. It is enabled when true.
 */
private bool getBackgroundRendererState(){
	return backgroundRendererState;
}


/**
 * !--- locale=Ja-JP ---
 * 前景2DCGレンダラーの有効/無効を制御する変数です。
 *
 * !--- locale=En-US ---
 * The variable controlling whether the foreground 2D CG renderer is enabled.
 */
private bool foregroundRendererState = false;

/**
 * !--- locale=Ja-JP ---
 * 前景2DCGレンダラーの有効/無効を設定します。
 *
 * @param state 前景2DCGレンダラーの有効/無効（trueならば有効）
 *
 * !--- locale=En-US ---
 * Sets whether the foreground 2D CG renderer is enabled.
 *
 * @param state Whether the foreground 2D CG renderer is enabled. It is enabled when true.
 */
public void setForegroundRendererState(bool state){
	if(state && !backgroundRendererState){
		error(ERROR_BACKGROUND_RENDERER_IS_DISABLED_AND_FOREGRAUND_RENDERER_IS_ENABLED);
	}
	foregroundRendererState = state;
	if(foregroundGraphics == NULL){
		int width = getPreferredScreenWidth();
		int height = getPreferredScreenHeight();
		foregroundGraphics = newGraphics();
		foregroundRenderer = newGraphics2DRenderer( width, height, foregroundGraphics );
	}
	setGraphicsLabelRenderer();
}

/**
 * !--- locale=Ja-JP ---
 * 前景2DCGレンダラーの有効/無効を取得します。
 *
 * @return 前景2DCGレンダラーの有効/無効（trueならば有効）
 *
 * !--- locale=En-US ---
 * Gets whether the foreground 2D CG renderer is enabled.
 *
 * @return Whether the foreground 2D CG renderer is enabled. It is enabled when true.
 */
private bool getForegroundRendererState(){
	return foregroundRendererState;
}


/**
 * !--- locale=Ja-JP ---
 * 描画内容を表示する、画像ラベルのGUIコンポーネントIDです。
 *
 * !--- locale=En-US ---
 * The GUI component ID of the image label displaying the drawing contents.
 */
private int imageLabel = NULL;

/**
 * !--- locale=Ja-JP ---
 * 描画内容を表示する、画像ラベルのGUIコンポーネントIDを返します。
 *
 * @return 画像ラベルのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * Returns the GUI component ID of the image label displaying the drawing contents.
 *
 * @return The GUI component ID of the image label.
 */
public int getImageLabel(){
	return imageLabel;
}

/**
 * !--- locale=Ja-JP ---
 * 画像ラベルのGUIコンポーネントIDを返します。
 * この関数は、より新しい <a href="#getImageLabel">getImageLabel</a> 関数がサポートされています。
 * この関数は互換目的でサポートされています。
 *
 * @return 画像ラベルのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * Returns the GUI component ID of the image label.
 * The newer <a href="#getImageLabel">getImageLabel</a> function is available for this purpose.
 * This function is supported for compatibility.
 *
 * @return The GUI component ID of the image label.
 */
public int getGraphicsLabel(){
	return imageLabel;
}


/**
 * !--- locale=Ja-JP ---
 * ウィンドウのGUIコンポーネントIDです。
 *
 * !--- locale=En-US ---
 * The GUI component ID of the window.
 */
private int window = NULL;

/**
 * !--- locale=Ja-JP ---
 * ウィンドウのGUIコンポーネントIDを取得します。
 *
 * @return ウィンドウのGUIコンポーネントID
 *
 * !--- locale=En-US ---
 * Gets the GUI component ID of the window.
 *
 * @return The GUI component ID of the window.
 */
public int getWindow(){
	return window;
}


/**
 * !--- locale=Ja-JP ---
 * アニメーションモードの有効/無効を制御する変数です。
 *
 * !--- locale=En-US ---
 * The variable controlling whether animation mode is enabled.
 */
private bool animation = true;

/**
 * !--- locale=Ja-JP ---
 * アニメーションモードの有効/無効を設定します。
 *
 * @param enable アニメーションモードの有効/無効(trueならば有効)
 *
 * !--- locale=En-US ---
 * Sets whether animation mode is enabled.
 *
 * @param enable Whether animation mode is enabled. It is enabled when true.
 */
public void setAnimationState(bool enable){
	animation = enable;
}

/**
 * !--- locale=Ja-JP ---
 * アニメーションの有効/無効を取得します。
 *
 * @return アニメーションモード有効/無効(trueならば有効)
 *
 * !--- locale=En-US ---
 * Gets whether animation mode is enabled.
 *
 * @return Whether animation mode is enabled. It is enabled when true.
 */
public bool getAnimationState(){
	return animation;
}


/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）の設定値です。
 *
 * !--- locale=En-US ---
 * The configured screen update frequency of the animation, that is, the number of redraws per second.
 */
private float frameRate = 30;

/**
 * !--- locale=Ja-JP ---
 * アニメーションの画面更新頻度（ 1秒間あたりの描画回数 ）を設定します。
 *
 * @param rate 画面更新頻度
 *
 * !--- locale=En-US ---
 * Sets the screen update frequency of the animation, that is, the number of redraws per second.
 *
 * @param rate The screen update frequency.
 */
public void setFrameRate(float rate){
