# PRAGMA RESERVE    ALL
# 
# PRAGMA INTERNAL   RINEARN  {
#     
#     MAINSTREAM    { "R4***",    "OR_LATER" }
#     COMPATIBLE    { "R3***",    "R2***",    "R1***"    }
#     
#     SYSTEMCALL    { "SYSTEM_PROCESS_DRIVER_GRAPH2D_*" }
#     INTERFACE     { "GPCI",     "DPCI" }
#     
#     CONNECT       { "ONLOAD",   "STATIC",   "rxvesapi.process.driver.Graph2DProcessDriver"   }
#     ARCHIVE       { "ONBUILD",  "STATIC",   "rxvesapi.process.library.Graph2DProcessLibrary" }
#     
# }
# 
# PRAGMA INTERNAL   END
# PRAGMA END

/**
 * !--- locale=Ja-JP ---
 * <p>
 * tool.Graph2D APIライブラリ（以下、Graph2Dライブラリ）は、2次元グラフソフトウェアを制御するためのライブラリです。
 * </p>
 *
 * <p>
 * Graph2D ライブラリは拡張ライブラリであり、VCSSLの言語仕様における標準ライブラリには含まれていません。従って、全てのVCSSL処理系において、必ずしもGraph2D ライブラリの実装がサポートされるわけではありません。
 * </p>
 *
 * <p>
 * Graph2D ライブラリの仕様は、広く一般的な2次元グラフソフトウェアをVCSSLから制御する事を想定して定義されており、特定の2次元グラフソフトウェアを前提としたものではありません。 Graph2D ライブラリの実装において、制御対象にどのような2次元グラフソフトウェアが採用されるかは処理系依存であり、処理系の開発元（ベンダー）、バージョン、またはグラフソフトウェアとの通信機能を提供するプラグインなどに依存します。このような事情があるため、Graph2D ライブラリが提供する各種関数も、異なる処理系に関しては、厳密に同一の挙動を期待すべきではありません。
 * </p>
 *
 * <p>
 * また、同一の処理系であっても、Graph2D ライブラリは標準ライブラリでは無いため、その実装において、恒久的に同様の挙動が保証されるものではありません。Graph2D ライブラリの実装は、あくまで処理系が独自にサポートする拡張機能であるという点に留意しておく必要があります。例えば、グラフソフトウェアの大幅なアップデートが行われると、 それに伴い、Graph2D ライブラリの挙動も微妙に変化してしまうケースなどが考えられます。
 * </p>
 *
 * <p>
 * RINEARN VCSSLランタイム、及びそれを搭載するVCSSL対応ソフトウェア（リニアンプロセッサーなど）では、
 * Graph2D ライブラリをサポートしており、その実装には科学技術分野用グラフソフトウェア「 リニアングラフ2D 」を採用しています。
 * リニアングラフ2D本体（ RinearnGraph2D.jar ）はVCSSLランタイムの配布パッケージ内に同梱されているため、
 * 別途何かを用意する必要はありません。
 * </p>
 *
 * @author  松井文宏 ( RINEARN )
 * @license Public domain ( CC0 )
 *
 * !--- locale=En-US ---
 * <p>
 * The tool.Graph2D API library, hereafter the Graph2D library, is a library for controlling 2D graph software.
 * </p>
 *
 * <p>
 * The Graph2D library is an extension library and is not included in the standard libraries defined by the VCSSL language specification. Therefore, support for the Graph2D library implementation is not guaranteed in every VCSSL implementation.
 * </p>
 *
 * <p>
 * The specification of the Graph2D library is defined assuming control of widely used general-purpose 2D graph software from VCSSL, and it is not intended for a specific 2D graph application. In an implementation of the Graph2D library, what kind of 2D graph software is adopted as the control target depends on the implementation, the vendor of the implementation, its version, or plugins that provide communication functions with graph software. Because of these circumstances, the functions provided by the Graph2D library should not be expected to behave in exactly the same way across different implementations.
 * </p>
 *
 * <p>
 * Even in the same implementation, because the Graph2D library is not a standard library, its implementation is not guaranteed to behave permanently in the same way. Keep in mind that the implementation of the Graph2D library is only an extension feature supported independently by the implementation. For example, if the graph software receives a major update, the behavior of the Graph2D library may also change slightly as a result.
 * </p>
 *
 * <p>
 * In the RINEARN VCSSL Runtime and VCSSL-supported software equipped with it, such as Rinearn Processor,
 * the Graph2D library is supported, and its implementation adopts the graph software RINRARN Graph 2D for scientific and technical fields.
 * Since the RINRARN Graph 2D program itself, RinearnGraph2D.jar, is bundled in the distribution package of the VCSSL Runtime,
 * nothing needs to be prepared separately.
 * </p>
 *
 * @author  Fumihiro Matsui ( RINEARN )
 * @license Public domain ( CC0 )
 */





/**
 * !--- locale=Ja-JP ---
 * エラーメッセージ、ファイルが見つからなかった場合。
 *
 * !--- locale=En-US ---
 * The error message used when the file is not found.
 */
private const string ERROR_FILE_NOT_FOUND = "File Not Found Error / ファイルが見つかりません: ";


/**
 * !--- locale=Ja-JP ---
 * 2次元グラフをデフォルトのサイズで生成し、それに固有の識別番号 ( グラフID ) を割り振って返します。
 *
 * @return 生成したグラフのID
 *
 * !--- locale=En-US ---
 * Creates a 2D graph with the default size, assigns its unique identifier, the graph ID, and returns it.
 *
 * @return The ID of the created graph.
 */
int newGraph2D(){
  return SYSTEM_PROCESS_DRIVER_GRAPH2D_newGraph2D();
}

/**
 * !--- locale=Ja-JP ---
 * 2次元グラフを指定されたサイズで生成し、それに固有の識別番号 ( グラフID ) を割り振って返します。
 *
 * @param x グラフウィンドウ左上頂点のX座標
 * @param y グラフウィンドウ左上頂点のY座標
 * @param width グラフウィンドウの幅
 * @param height グラフウィンドウの高さ
 * @param title グラフウィンドウタイトル
 * @return 生成したグラフのID
 *
 * !--- locale=En-US ---
 * Creates a 2D graph with the specified size, assigns its unique identifier, the graph ID, and returns it.
 *
 * @param x The X coordinate of the top-left corner of the graph window.
 * @param y The Y coordinate of the top-left corner of the graph window.
 * @param width The width of the graph window.
 * @param height The height of the graph window.
 * @param title The title of the graph window.
 * @return The ID of the created graph.
 */
int newGraph2D( int x, int y, int width, int height, string title ){
  int graphID = SYSTEM_PROCESS_DRIVER_GRAPH2D_newGraph2D();
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DWindowTitle( graphID, title );
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DLocation( graphID, x, y );
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DSize( graphID, width, height );
  return graphID;
}

/**
 * !--- locale=Ja-JP ---
 * 処理系で起動・確保されている特別なグラフがあれば、そのグラフIDを取得します。無ければ新規生成します。
 *
 * @return 取得または生成したグラフID
 *
 * !--- locale=En-US ---
 * If there is a special graph started and allocated by the implementation, gets its graph ID. Otherwise, creates a new one.
 *
 * @return The obtained or created graph ID.
 */
int getGraph2D(){
  return SYSTEM_PROCESS_DRIVER_GRAPH2D_getGraph2DSystemDefaultInstance();
}



