 * @param xTickCoords X軸の目盛り刻み位置の座標値
 * @param xTickLabels X軸の目盛りのラベル
 * @param yTickCoords Y軸の目盛り刻み位置の座標値
 * @param yTickLabels Y軸の目盛りのラベル
 *
 * !--- locale=En-US ---
 * Sets the tick marks of each axis.
 *
 * @param graphID The ID of the target graph.
 * @param xTickCoords The coordinate values of the tick positions on the X axis.
 * @param xTickLabels The labels of the tick marks on the X axis.
 * @param yTickCoords The coordinate values of the tick positions on the Y axis.
 * @param yTickLabels The labels of the tick marks on the Y axis.
 */
void setGraph2DTick( int graphID, double xTickCoords[], string xTickLabels[], double yTickCoords[], string yTickLabels[] ){
	setGraph2DTickX(graphID, xTickCoords, xTickLabels);
	setGraph2DTickY(graphID, yTickCoords, yTickLabels);
}

/**
 * !--- locale=Ja-JP ---
 * X軸の目盛りを設定します。
 *
 * @param graphID 対象グラフのID
 * @param tickCoords 目盛り刻み位置の座標値
 * @param tickLabels 目盛りのラベル
 *
 * !--- locale=En-US ---
 * Sets the tick marks of the X axis.
 *
 * @param graphID The ID of the target graph.
 * @param tickCoords The coordinate values of the tick positions.
 * @param tickLabels The labels of the tick marks.
 */
void setGraph2DTickX( int graphID, double tickCoords[], string tickLabels[] ){
	int tickCoordsN = length(tickCoords, 0);
	int tickLabelsN = length(tickLabels, 0);
	if (tickCoordsN != tickLabelsN) {
		error(
			"引数 tickCoords と tickLabels の要素数は同じに揃っている必要がありますが、異なっています。"
			+ EOL +
			"The length of tickCoords and tickLabels must be the same but different."
		);
		return;
	}
	string args[2 + tickCoordsN + tickLabelsN];
	args[0] = graphID;
	args[1] = tickCoordsN;
	int iarg = 2;
	for (int itick=0; itick<tickCoordsN; itick++) {
		args[iarg] = tickCoords[itick];
		iarg++;
	}
	for (int itick=0; itick<tickLabelsN; itick++) {
		args[iarg] = tickLabels[itick];
		iarg++;
	}
	SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DTickX(args);
}


/**
 * !--- locale=Ja-JP ---
 * Y軸の目盛りを設定します。
 *
 * @param graphID 対象グラフのID
 * @param tickCoords 目盛り刻み位置の座標値
 * @param tickLabels 目盛りのラベル
 *
 * !--- locale=En-US ---
 * Sets the tick marks of the Y axis.
 *
 * @param graphID The ID of the target graph.
 * @param tickCoords The coordinate values of the tick positions.
 * @param tickLabels The labels of the tick marks.
 */
void setGraph2DTickY( int graphID, double tickCoords[], string tickLabels[] ){
	int tickCoordsN = length(tickCoords, 0);
	int tickLabelsN = length(tickLabels, 0);
	if (tickCoordsN != tickLabelsN) {
		error(
			"引数 tickCoords と tickLabels の要素数は同じに揃っている必要がありますが、異なっています。"
			+ EOL +
			"The length of tickCoords and tickLabels must be the same but different."
		);
		return;
	}
	string args[2 + tickCoordsN + tickLabelsN];
	args[0] = graphID;
	args[1] = tickCoordsN;
	int iarg = 2;
	for (int itick=0; itick<tickCoordsN; itick++) {
		args[iarg] = tickCoords[itick];
		iarg++;
	}
	for (int itick=0; itick<tickLabelsN; itick++) {
		args[iarg] = tickLabels[itick];
		iarg++;
	}
	SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DTickY(args);
}


/**
 * !--- locale=Ja-JP ---
 * グラフのオプション項目を設定します。項目名は処理系に依存します。代表的なオプション項目名は以下の通りです：
 * <dl>
 * <dt>WITH_POINTS</dt>
 * <dd>点プロット</dd>
 * <dt>WITH_LINES</dt>
 * <dd>線プロット</dd>
 * <dt>WITH_DOTS</dt>
 * <dd>ドットプロット</dd>
 * <dt>WITH_GRID_LINE</dt>
 * <dd>グリッドライン描画</dd>
 * <dt>LOG_X</dt>
 * <dd>X対数軸表示</dd>
 * <dt>LOG_Y</dt>
 * <dd>Y対数軸表示</dd>
 * <dt>REVERSE_X</dt>
 * <dd>X軸反転表示</dd>
 * <dt>REVERSE_Y</dt>
 * <dd>Y軸反転表示</dd>
 * </dl>
 *
 * @param graphID 対象グラフのID
 * @param option オプション項目名
 * @param value オプションを有効にするならtrue、無効にするにはfalse
 *
 * !--- locale=En-US ---
 * Sets an option item of the graph. The item names depend on the implementation. Representative option item names are as follows:
 * <dl>
 * <dt>WITH_POINTS</dt>
 * <dd>Point plot</dd>
 * <dt>WITH_LINES</dt>
 * <dd>Line plot</dd>
 * <dt>WITH_DOTS</dt>
 * <dd>Dot plot</dd>
 * <dt>WITH_GRID_LINE</dt>
 * <dd>Grid-line drawing</dd>
 * <dt>LOG_X</dt>
 * <dd>Display the X axis in logarithmic scale</dd>
 * <dt>LOG_Y</dt>
 * <dd>Display the Y axis in logarithmic scale</dd>
 * <dt>REVERSE_X</dt>
 * <dd>Reverse the X axis</dd>
 * <dt>REVERSE_Y</dt>
 * <dd>Reverse the Y axis</dd>
 * </dl>
 *
 * @param graphID The ID of the target graph.
 * @param option The name of the option item.
 * @param value True to enable the option, or false to disable it.
 */
void setGraph2DOption( int graphID, string option, bool value ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DOption( graphID, option, value );
}

/**
 * !--- locale=Ja-JP ---
 * ※ この関数の用途は、事実上ラベル設定専用であり、現在は setGraph2DLabel 関数やsetGraph2DLabelX/Y 関数などで代替可能です。
 * そちらの方が可読性が高いため、特に事情が無ければ、今後はそちらを用いる事が推奨されます。
 * <br />
 * <br />
 * グラフのメニュー項目を設定します。項目名は処理系に依存します。
 *
 * @param graphID 対象グラフのID
 * @param option メニュー項目名
 * @param value メニュー項目を有効にするならtrue、無効にするにはfalse
 *
 * !--- locale=En-US ---
 * This function is effectively used only for label settings, and it can now be replaced by functions such as setGraph2DLabel and setGraph2DLabelX or Y.
 * Because that is more readable, it is recommended to use that form from now on unless there is a specific reason not to.
 * <br />
 * <br />
 * Sets a menu item of the graph. The item name depends on the implementation.
 *
 * @param graphID The ID of the target graph.
 * @param option The name of the menu item.
 * @param value True to enable the menu item, or false to disable it.
 */
void setGraph2DMenu( int graphID, string menu, string value ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DMenu( graphID, menu, value );
}


/**
 * !--- locale=Ja-JP ---
 * グラフのアニメーションを有効化または無効化します。利用可能なアニメーションモードは処理系に依存します。代表的なアニメーションモードは以下の通りです：
 * <dl>
 * <dt>TRACE</dt>
 * <dd>点をアニメーションし、軌跡を残す</dd>
 * <dt>INDEX</dt>
 * <dd>点をアニメーションする</dd>
 * <dt>INDEX-SERIES</dt>
 * <dd>系列をアニメーションする</dd>
 * </dl>
 *
 * @param graphID 対象グラフのID
 * @param mode アニメーションモード
 * @param state アニメーションを有効化するならtrue、無効化するならfalse
 *
 * !--- locale=En-US ---
 * Enables or disables graph animation. The available animation modes depend on the implementation. Representative animation modes are as follows:
 * <dl>
 * <dt>TRACE</dt>
 * <dd>Animate points while leaving trajectories</dd>
 * <dt>INDEX</dt>
 * <dd>Animate points</dd>
 * <dt>INDEX-SERIES</dt>
 * <dd>Animate series</dd>
 * </dl>
 *
 * @param graphID The ID of the target graph.
 * @param mode The animation mode.
 * @param state True to enable animation, or false to disable it.
 */
void setGraph2DAnimation( int graphID, string mode, bool state ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DAnimation( graphID, mode, state );
}

/**
 * !--- locale=Ja-JP ---
 * グラフのタイトルを設定します。
 *
 * @param graphID 対象グラフのID
 * @param title タイトル
 *
 * !--- locale=En-US ---
 * Sets the title of the graph.
 *
 * @param graphID The ID of the target graph.
 * @param title The title.
 */
void setGraph2DTitle( int graphID, string title ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DTitle( graphID, title );
}

/**
 * !--- locale=Ja-JP ---
 * グラフの軸ラベルを設定します。
 *
 * @param graphID 対象グラフのID
 * @param xLabel X軸のラベル
 * @param yLabel Y軸のラベル
 *
 * !--- locale=En-US ---
 * Sets the axis labels of the graph.
 *
 * @param graphID The ID of the target graph.
 * @param xLabel The label of the X axis.
 * @param yLabel The label of the Y axis.
 */
void setGraph2DLabel( int graphID, string xLabel, string yLabel ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DLabel( graphID, xLabel, yLabel );
}

/**
 * !--- locale=Ja-JP ---
 * グラフの凡例を設定します。
 *
 * @param graphID 対象グラフのID
 * @param legend 凡例を格納する配列（ [ 系列インデックス ] ）
 *
 * !--- locale=En-US ---
 * Sets the legend of the graph.
 *
 * @param graphID The ID of the target graph.
 * @param legend The array storing the legends, indexed by series index.
 */
void setGraph2DLegend( int graphID, string legend[] ){
  int L = length( legend );
  string arg[ L+1 ];
  arg[0] = graphID;
  for( int i=1; i<=L; i++ ){
    arg[i] = legend[i-1];
  }
  SYSTEM_PROCESS_DRIVER_GRAPH2D_setGraph2DLegend( arg );
}


/**
 * !--- locale=Ja-JP ---
 * グラフを画像に出力します。
 *
 * @param graphID 対象グラフのID
 * @param filename 出力ファイル名またはパス
 * @param 形式（ "PNG" または "JPEG" ）
 *
 * !--- locale=En-US ---
 * Outputs the graph as an image.
 *
 * @param graphID The ID of the target graph.
 * @param filename The output file name or path.
 * @param format The format, either "PNG" or "JPEG".
 */
void exportGraph2D( int graphID, string filename, string format ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_exportGraph2D( graphID, filename, format, 100.0 );
}

/**
 * !--- locale=Ja-JP ---
 * グラフを画像に出力します。
 *
 * @param graphID 対象グラフのID
 * @param filename 出力ファイル名またはパス
 * @param 形式（ "PNG" または "JPEG" ）
 * @param quality 品質（ 0.0 ~ 100.0 ）
 *
 * !--- locale=En-US ---
 * Outputs the graph as an image.
 *
 * @param graphID The ID of the target graph.
 * @param filename The output file name or path.
 * @param format The format, either "PNG" or "JPEG".
 * @param quality The quality, from 0.0 to 100.0.
 */
void exportGraph2D( int graphID, string filename, string format, float quality ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_exportGraph2D( graphID, filename, format, quality );
}


void exportGraph2DData( int graphID, string filename, string format ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_exportGraph2DData( graphID, filename, format );
}


