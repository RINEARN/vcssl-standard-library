 *
 * !--- locale=En-US ---
 * Destroys the graph.
 *
 * @param graphID The ID of the target graph.
 */
void deleteGraph2D( int graphID ){
  SYSTEM_PROCESS_DRIVER_GRAPH2D_deleteGraph2D( graphID );
}

/**
 * !--- locale=Ja-JP ---
 * グラフの内容をクリアします。
 *
