 *
 * !--- locale=En-US ---
 * Loads text written in the same format as the contents of a file and plots it on the graph.
 *
 * @param graphID The ID of the target graph.
 * @param data The text written in the same format as the contents of a file.
 */
void setGraph3DData( int graphID, string data ){
  SYSTEM_PROCESS_DRIVER_GRAPH3D_setGraph3DDataString( graphID, data );
}


/**
 * !--- locale=Ja-JP ---
 * 座標値を格納する float 型配列を読み込み、グラフにプロットします。
 *
 * @param graphID 対象グラフのID
 * @param dataX X座標を格納する配列（ [ 点インデックス ] ）
 * @param dataY Y座標を格納する配列（ [ 点インデックス ] ）
 * @param dataZ Z座標を格納する配列（ [ 点インデックス ] ）
 *
 * !--- locale=En-US ---
 * Loads float arrays storing coordinate values and plots them on the graph.
 *
 * @param graphID The ID of the target graph.
 * @param dataX The array storing the X coordinates, indexed by point index.
 * @param dataY The array storing the Y coordinates, indexed by point index.
 * @param dataZ The array storing the Z coordinates, indexed by point index.
 */
void setGraph3DData( int graphID, float dataX[], float dataY[], float dataZ[] ){
  SYSTEM_PROCESS_DRIVER_GRAPH3D_setGraph3DData( graphID, dataX, dataY, dataZ );
}

/**
 * !--- locale=Ja-JP ---
 * 座標値を格納する float 型配列を読み込み、グラフにプロットします。
 *
 * @param graphID 対象グラフのID
 * @param dataX X座標を格納する配列（ [ メッシュ上のY方向インデックス ][ メッシュ上のX方向インデックス ] ）
 * @param dataY Y座標を格納する配列（ [ メッシュ上のY方向インデックス ][ メッシュ上のX方向インデックス ] ）
 * @param dataZ Z座標を格納する配列（ [ メッシュ上のY方向インデックス ][ メッシュ上のX方向インデックス ] ）
 *
 * !--- locale=En-US ---
 * Loads float arrays storing coordinate values and plots them on the graph.
 *
 * @param graphID The ID of the target graph.
 * @param dataX The array storing the X coordinates, indexed by Y-direction index on the mesh and X-direction index on the mesh.
 * @param dataY The array storing the Y coordinates, indexed by Y-direction index on the mesh and X-direction index on the mesh.
 * @param dataZ The array storing the Z coordinates, indexed by Y-direction index on the mesh and X-direction index on the mesh.
 */
void setGraph3DData( int graphID, float dataX[][], float dataY[][], float dataZ[][] ){
  SYSTEM_PROCESS_DRIVER_GRAPH3D_setGraph3DData( graphID, dataX, dataY, dataZ );
}

