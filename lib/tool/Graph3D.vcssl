coding UTF-8;

# PRAGMA COMPILE    REFERRAL
# PRAGMA RESERVE    ALL
# 
# PRAGMA INTERNAL   RINEARN  {
#     
#     MAINSTREAM    { "R4***",    "OR_LATER" }
#     COMPATIBLE    { "R3***",    "R2***",    "R1***"    }
#     
#     SYSTEMCALL    { "SYSTEM_PROCESS_DRIVER_GRAPH3D_*" }
#     INTERFACE     { "GPCI",     "DPCI" }
#     
#     CONNECT       { "ONLOAD",   "STATIC",   "rxvesapi.process.driver.Graph3DProcessDriver"   }
#     ARCHIVE       { "ONBUILD",  "STATIC",   "rxvesapi.process.library.Graph3DProcessLibrary" }
#     
# }
# 
# PRAGMA INTERNAL   END
# PRAGMA END

/**
 * !--- locale=Ja-JP ---
 * <p>
 * tool.Graph3D ライブラリ APIライブラリ（以下、Graph3D ライブラリライブラリ）は、3次元グラフソフトウェアを制御するためのライブラリです。
 * </p>
 *
 * <p>
 * Graph3D ライブラリは拡張ライブラリであり、VCSSLの言語仕様における標準ライブラリには含まれていません。従って、全てのVCSSL処理系において、必ずしもGraph3D ライブラリの実装がサポートされるわけではありません。
 * </p>
 *
 * <p>
 * Graph3D ライブラリの仕様は、広く一般的な3次元グラフソフトウェアをVCSSLから制御する事を想定して定義されており、特定の3次元グラフソフトウェアを前提としたものではありません。 Graph3D ライブラリの実装において、制御対象にどのような3次元グラフソフトウェアが採用されるかは処理系依存であり、処理系の開発元（ベンダー）、バージョン、またはグラフソフトウェアとの通信機能を提供するプラグインなどに依存します。このような事情があるため、Graph3D ライブラリが提供する各種関数も、異なる処理系に関しては、厳密に同一の挙動を期待すべきではありません。
 * </p>
 *
 * <p>
 * また、同一の処理系であっても、Graph3D ライブラリは標準ライブラリでは無いため、その実装において、恒久的に同様の挙動が保証されるものではありません。Graph3D ライブラリの実装は、あくまで処理系が独自にサポートする拡張機能であるという点に留意しておく必要があります。例えば、グラフソフトウェアの大幅なアップデートが行われると、 それに伴い、Graph3D ライブラリの挙動も微妙に変化してしまうケースなどが考えられます。
 * </p>
 *
 * <p>
 * RINEARN VCSSLランタイム、及びそれを搭載するVCSSL対応ソフトウェア（リニアンプロセッサーなど）では、
 * Graph3D ライブラリをサポートしており、その実装には科学技術分野用グラフソフトウェア「 リニアングラフ3D 」を採用しています。
 * リニアングラフ3D本体（ RinearnGraph3D ライブラリ.jar ）はVCSSLランタイムの配布パッケージ内に同梱されているため、
 * 別途何かを用意する必要はありません。
 * </p>
 *
 * @author  松井文宏 ( RINEARN )
 * @license Public domain ( CC0 )
 *
 * !--- locale=En-US ---
 * <p>
 * The tool.Graph3D API library, hereafter the Graph3D library, is a library for controlling 3D graph software.
 * </p>
 *
 * <p>
 * The Graph3D library is an extension library and is not included in the standard libraries defined by the VCSSL language specification. Therefore, support for the Graph3D library implementation is not guaranteed in every VCSSL implementation.
 * </p>
 *
 * <p>
 * The specification of the Graph3D library is defined assuming control of widely used general-purpose 3D graph software from VCSSL, and it is not intended for a specific 3D graph application. In an implementation of the Graph3D library, what kind of 3D graph software is adopted as the control target depends on the implementation, the vendor of the implementation, its version, or plugins that provide communication functions with graph software. Because of these circumstances, the functions provided by the Graph3D library should not be expected to behave in exactly the same way across different implementations.
 * </p>
 *
 * <p>
 * Even in the same implementation, because the Graph3D library is not a standard library, its implementation is not guaranteed to behave permanently in the same way. Keep in mind that the implementation of the Graph3D library is only an extension feature supported independently by the implementation. For example, if the graph software receives a major update, the behavior of the Graph3D library may also change slightly as a result.
 * </p>
 *
 * <p>
 * In the RINEARN VCSSL Runtime and VCSSL-supported software equipped with it, such as Rinearn Processor,
 * the Graph3D library is supported, and its implementation adopts the graph software RINRARN Graph 3D for scientific and technical fields.
 * Since the RINRARN Graph 3D program itself, RinearnGraph3D.jar, is bundled in the distribution package of the VCSSL Runtime,
 * nothing needs to be prepared separately.
 * </p>
 *
 * @author  Fumihiro Matsui ( RINEARN )
 * @license Public domain ( CC0 )
 */





/**
 * !--- locale=Ja-JP ---
 * エラーメッセージ、ファイルが見つからなかった場合。
 * !--- locale=En-US ---
 * The error message used when the file is not found.
 */
private const string ERROR_FILE_NOT_FOUND = "File Not Found Error / ファイルが見つかりません: ";


/**
 * !--- locale=Ja-JP ---
 * 3次元グラフをデフォルトのサイズで生成し、それに固有の識別番号 ( グラフID ) を割り振って返します。
 *
 * @return 生成したグラフのID
 *
 * !--- locale=En-US ---
 * Creates a 3D graph with the default size, assigns its unique identifier, the graph ID, and returns it.
 *
 * @return The ID of the created graph.
 */
int newGraph3D(){
  return SYSTEM_PROCESS_DRIVER_GRAPH3D_newGraph3D();
}

/**
 * !--- locale=Ja-JP ---
 * 3次元グラフを指定されたサイズで生成し、それに固有の識別番号 ( グラフID ) を割り振って返します。
 *
 * @param x グラフウィンドウ左上頂点のX座標
 * @param y グラフウィンドウ左上頂点のY座標
 * @param width グラフウィンドウの幅
 * @param height グラフウィンドウの高さ
 * @param title グラフウィンドウタイトル
 * @return 生成したグラフのID
 *
 * !--- locale=En-US ---
 * Creates a 3D graph with the specified size, assigns its unique identifier, the graph ID, and returns it.
 *
 * @param x The X coordinate of the top-left corner of the graph window.
 * @param y The Y coordinate of the top-left corner of the graph window.
 * @param width The width of the graph window.
 * @param height The height of the graph window.
 * @param title The title of the graph window.
 * @return The ID of the created graph.
 */
int newGraph3D( int x, int y, int width, int height, string title ){
  int graphID = SYSTEM_PROCESS_DRIVER_GRAPH3D_newGraph3D();
  SYSTEM_PROCESS_DRIVER_GRAPH3D_setGraph3DWindowTitle( graphID, title );
  SYSTEM_PROCESS_DRIVER_GRAPH3D_setGraph3DLocation( graphID, x, y );
  SYSTEM_PROCESS_DRIVER_GRAPH3D_setGraph3DSize( graphID, width, height );
  return graphID;
}

/**
 * !--- locale=Ja-JP ---
 * 処理系で起動・確保されている特別なグラフがあれば、そのグラフIDを取得します。無ければ新規生成します。
 *
 * @return 取得または生成したグラフID
 *
 * !--- locale=En-US ---
 * If there is a special graph started and allocated by the implementation, gets its graph ID. Otherwise, creates a new one.
 *
 * @return The obtained or created graph ID.
 */
int getGraph3D(){
  return SYSTEM_PROCESS_DRIVER_GRAPH3D_getGraph3DSystemDefaultInstance();
}

/**
 * !--- locale=Ja-JP ---
 * グラフを破棄します。
 *
 * @param graphID 対象グラフのID
 *
 * !--- locale=En-US ---
 * Destroys the graph.
 *
 * @param graphID The ID of the target graph.
 */
void deleteGraph3D( int graphID ){
  SYSTEM_PROCESS_DRIVER_GRAPH3D_deleteGraph3D( graphID );
}

/**
 * !--- locale=Ja-JP ---
 * グラフの内容をクリアします。
 *
 * @param graphID 対象グラフのID
 *
 * !--- locale=En-US ---
 * Clears the contents of the graph.
 *
 * @param graphID The ID of the target graph.
 */
void clearGraph3D( int graphID ){
  SYSTEM_PROCESS_DRIVER_GRAPH3D_clearGraph3D( graphID );
}

/**
 * !--- locale=Ja-JP ---
 * グラフの保持している描画内容を、Graphicsライブラリ互換のグラフィックスデータに変換します。
 * 変換されたグラフィックスデータは、2D/3Dレンダラ―などで加工できます。
 *
 * @param graphID 対象グラフのID
 * @return グラフィックスデータID
 *
 * !--- locale=En-US ---
 * Converts the drawing contents held by the graph into graphics resource compatible with the Graphics library.
 * The converted graphics resource can be processed with a 2D or 3D renderer and so on.
 *
 * @param graphID The ID of the target graph.
 * @return The graphics resource ID.
 */
int getGraph3DGraphics( int graphID ){
  return SYSTEM_PROCESS_DRIVER_GRAPH3D_newGraph3DGraphics( graphID );
}

// ※ 改名/拡張案：
//    後々で getGraphics2DImage を追加する場合、そちらはその瞬間のグラフスクリーンのスナップショットを返すようにする。
//    getGraphics2DGraphics は、リアルタイムで更新され得るグラフィックスリソースを返すものとして、共存させる。


